<div class="img-banner full-width">
  <div class="img-banner__wrap">
    {% if section.settings.image %}
      {{ section.settings.image | image_url: width: 2000 | image_tag: class: 'img-banner__img', loading: 'lazy', alt: '' }}
    {% else %}
      <img src="{{ 'image-banner.jpg' | asset_url }}" alt="" class="img-banner__img" loading="lazy">
    {% endif %}

    {% if section.settings.overlay_opacity > 0 %}
      <div class="img-banner__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
    {% endif %}

    {%- for block in section.blocks -%}
      {%- if block.type == 'hotspot' -%}
        {%- assign hp = all_products[block.settings.product] -%}
        {%- assign x = block.settings.hotspot_x -%}
        {%- assign y = block.settings.hotspot_y -%}
        {%- assign popup_class = '' -%}
        {%- if x > 60 -%}{%- assign popup_class = 'img-banner__hotspot--flip-x' -%}{%- endif -%}
        {%- if y > 65 -%}{%- assign popup_class = popup_class | append: ' img-banner__hotspot--flip-y' -%}{%- endif -%}

        <div class="img-banner__hotspot {{ popup_class }}"
             style="left: {{ x }}%; top: {{ y }}%;"
             data-hotspot
             {{ block.shopify_attributes }}>
          <button class="img-banner__hotspot-btn" aria-label="View product" aria-expanded="false">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 1V13M1 7H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>

          <div class="img-banner__popup" role="tooltip">
            {%- if hp != blank -%}
              <a href="{{ hp.url }}" class="img-banner__popup-link">
                <p class="img-banner__popup-name">{{ hp.title }}</p>
                <p class="img-banner__popup-price">{{ hp.price | money }}</p>
              </a>
            {%- elsif block.settings.fallback_title != blank -%}
              <p class="img-banner__popup-name">{{ block.settings.fallback_title }}</p>
              {%- if block.settings.fallback_price != blank -%}
                <p class="img-banner__popup-price">{{ block.settings.fallback_price }}</p>
              {%- endif -%}
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .img-banner {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .img-banner__wrap {
    position: relative;
    width: 100%;
    height: 718px;
  }

  .img-banner__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .img-banner__overlay {
    position: absolute;
    inset: 0;
    background: #000;
    pointer-events: none;
  }

  /* ── Hotspot ── */
  .img-banner__hotspot {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 10;
  }

  .img-banner__hotspot-btn {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.72);
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: background 0.2s, transform 0.15s;
    flex-shrink: 0;
  }

  .img-banner__hotspot-btn:hover,
  .img-banner__hotspot--open .img-banner__hotspot-btn {
    background: #000;
    transform: scale(1.08);
  }

  /* ── Popup ── */
  .img-banner__popup {
    position: absolute;
    left: 50%;
    top: calc(100% + 10px);
    transform: translateX(-50%) translateY(6px);
    background: rgba(245, 235, 225, 0.96);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 14px;
    padding: 14px 20px;
    min-width: 200px;
    max-width: 280px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
  }

  /* Show on hover (desktop) */
  .img-banner__hotspot:hover .img-banner__popup,
  .img-banner__hotspot--open .img-banner__popup {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  /* Flip horizontally when hotspot is near right edge */
  .img-banner__hotspot--flip-x .img-banner__popup {
    left: auto;
    right: 0;
    transform: translateX(0) translateY(6px);
  }
  .img-banner__hotspot--flip-x:hover .img-banner__popup,
  .img-banner__hotspot--flip-x.img-banner__hotspot--open .img-banner__popup {
    transform: translateX(0) translateY(0);
  }

  /* Flip vertically when hotspot is near bottom edge */
  .img-banner__hotspot--flip-y .img-banner__popup {
    top: auto;
    bottom: calc(100% + 10px);
    transform: translateX(-50%) translateY(-6px);
  }
  .img-banner__hotspot--flip-y:hover .img-banner__popup,
  .img-banner__hotspot--flip-y.img-banner__hotspot--open .img-banner__popup {
    transform: translateX(-50%) translateY(0);
  }

  .img-banner__hotspot--flip-x.img-banner__hotspot--flip-y .img-banner__popup {
    top: auto;
    bottom: calc(100% + 10px);
    left: auto;
    right: 0;
    transform: translateX(0) translateY(-6px);
  }
  .img-banner__hotspot--flip-x.img-banner__hotspot--flip-y:hover .img-banner__popup,
  .img-banner__hotspot--flip-x.img-banner__hotspot--flip-y.img-banner__hotspot--open .img-banner__popup {
    transform: translateX(0) translateY(0);
  }

  .img-banner__popup-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .img-banner__popup-name {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    color: #111;
    margin: 0 0 4px;
    line-height: 1.3;
    white-space: normal;
  }

  .img-banner__popup-price {
    font-family: var(--font-body);
    font-size: 14px;
    color: #555;
    margin: 0;
    font-weight: 400;
  }

  @media (max-width: 1100px) {
    .img-banner__wrap { height: 560px; }
  }

  @media (max-width: 768px) {
    .img-banner__wrap { height: 420px; }
    .img-banner__hotspot-btn { width: 28px; height: 28px; border-radius: 6px; }
    .img-banner__popup { min-width: 160px; padding: 10px 14px; font-size: 13px; }
    .img-banner__popup-name { font-size: 13px; }
    .img-banner__popup-price { font-size: 12px; }
  }

  @media (max-width: 480px) {
    .img-banner__wrap { height: 320px; }
  }
{% endstylesheet %}

<script>
  (function() {
    var hotspots = document.querySelectorAll('[data-hotspot]');
    hotspots.forEach(function(hotspot) {
      var btn = hotspot.querySelector('.img-banner__hotspot-btn');
      if (!btn) return;

      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var isOpen = hotspot.classList.contains('img-banner__hotspot--open');
        hotspots.forEach(function(h) {
          h.classList.remove('img-banner__hotspot--open');
          var b = h.querySelector('.img-banner__hotspot-btn');
          if (b) b.setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          hotspot.classList.add('img-banner__hotspot--open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });

    document.addEventListener('click', function() {
      hotspots.forEach(function(h) {
        h.classList.remove('img-banner__hotspot--open');
        var b = h.querySelector('.img-banner__hotspot-btn');
        if (b) b.setAttribute('aria-expanded', 'false');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Image Banner",
  "blocks": [
    {
      "type": "hotspot",
      "name": "Product Hotspot",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "fallback_title",
          "label": "Product name (if no product selected)"
        },
        {
          "type": "text",
          "id": "fallback_price",
          "label": "Price text (if no product selected)"
        },
        {
          "type": "range",
          "id": "hotspot_x",
          "label": "Position – left %",
          "min": 2,
          "max": 98,
          "step": 1,
          "default": 30
        },
        {
          "type": "range",
          "id": "hotspot_y",
          "label": "Position – top %",
          "min": 2,
          "max": 98,
          "step": 1,
          "default": 30
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Image Banner",
      "blocks": [
        {
          "type": "hotspot",
          "settings": {
            "fallback_title": "Gold Proposal Engagement Ring",
            "fallback_price": "LKR 12,000.00",
            "hotspot_x": 30,
            "hotspot_y": 28
          }
        }
      ]
    }
  ]
}
{% endschema %}
