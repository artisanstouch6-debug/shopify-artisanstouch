<div class="img-banner full-width">
  {% if section.settings.image %}
    {{ section.settings.image | image_url: width: 2000 | image_tag: class: 'img-banner__img', loading: 'lazy', alt: section.settings.heading | default: '' }}
  {% else %}
    <img src="{{ 'image-banner.jpg' | asset_url }}" alt="" class="img-banner__img" loading="lazy">
  {% endif %}
  {% if section.settings.overlay_opacity > 0 %}
    <div class="img-banner__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  {% endif %}
  {% if section.settings.heading != blank %}
    <div class="img-banner__content">
      <h2 class="img-banner__heading">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .img-banner {
    position: relative;
    height: 718px;
    overflow: hidden;
  }

  .img-banner__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .img-banner__placeholder {
    background: linear-gradient(135deg, #c9a07a, #8b6340);
  }

  .img-banner__overlay {
    position: absolute;
    inset: 0;
    background: #000;
  }

  .img-banner__content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 120px;
  }

  .img-banner__heading {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 700;
    color: white;
    text-align: center;
    margin: 0;
  }

  @media (max-width: 768px) {
    .img-banner { height: 400px; }
    .img-banner__heading { font-size: 32px; }
    .img-banner__content { padding: 40px 20px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Image Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (optional)"
    }
  ],
  "presets": [
    {
      "name": "Image Banner"
    }
  ]
}
{% endschema %}
