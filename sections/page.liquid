{% comment %}
  Page template section — Hero + content for About Us, Contact, and other pages.
{% endcomment %}

<!-- ── Page Hero ───────────────────────────────── -->
<section class="page-hero full-width">
  {%- if section.settings.hero_image != blank -%}
    {{ section.settings.hero_image | image_url: width: 1800 | image_tag:
        class: 'page-hero__bg',
        loading: 'eager',
        fetchpriority: 'high',
        alt: '' }}
  {%- else -%}
    <div class="page-hero__bg page-hero__bg--empty"></div>
  {%- endif -%}
  <div class="page-hero__overlay"></div>
  <div class="page-hero__text">
    <h1 class="page-hero__title">{{ page.title }}</h1>
  </div>
</section>

<!-- ── Page Content ────────────────────────────── -->
<section class="page-content full-width">
  <div class="page-content__inner">
    <div class="page-content__body rte">
      {{ page.content }}
    </div>
  </div>
</section>

{% stylesheet %}
/* ── Body ────────────────────────────────────────── */
body.template-page {
  background: #fff8f8;
  padding-top: 0 !important;
}

/* ── Hero ────────────────────────────────────────── */
.page-hero {
  position: relative;
  height: 65vh;
  min-height: 440px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.page-hero__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center center;
  display: block;
}

.page-hero__bg--empty {
  background: #1a1a1a;
}

.page-hero__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.52);
}

.page-hero__text {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 0 24px;
}

.page-hero__title {
  font-family: var(--font-heading);
  font-size: 72px;
  font-weight: 400;
  color: #fff;
  margin: 0;
  line-height: 1.1;
  letter-spacing: 0.02em;
}

/* ── Content section ─────────────────────────────── */
.page-content {
  background: #fff8f8;
}

.page-content__inner {
  max-width: 1440px;
  width: 100%;
  box-sizing: border-box;
  margin: 0 auto;
  padding: 72px 120px 100px;
}

.page-content__body {
  max-width: 760px;
  margin: 0 auto;
}

/* ── Rich text (rte) typography ──────────────────── */
.rte h1, .rte h2, .rte h3, .rte h4 {
  font-family: var(--font-heading);
  color: #111;
  margin: 0 0 16px;
  line-height: 1.2;
}

.rte h2 { font-size: 32px; font-weight: 500; }
.rte h3 { font-size: 24px; font-weight: 500; }

.rte p {
  font-family: var(--font-body);
  font-size: 16px;
  color: #444;
  line-height: 1.8;
  margin: 0 0 20px;
}

.rte a {
  color: var(--coral-pink, #ff9696);
  text-decoration: underline;
  transition: opacity 0.2s;
}

.rte a:hover { opacity: 0.75; }

.rte ul, .rte ol {
  font-family: var(--font-body);
  font-size: 16px;
  color: #444;
  line-height: 1.8;
  padding-left: 24px;
  margin: 0 0 20px;
}

.rte img {
  max-width: 100%;
  border-radius: 12px;
  display: block;
  margin: 24px 0;
}

/* ── Responsive ──────────────────────────────────── */
@media (max-width: 1200px) {
  .page-content__inner { padding: 56px 60px 80px; }
  .page-hero__title { font-size: 56px; }
}

@media (max-width: 960px) {
  .page-content__inner { padding: 48px 32px 64px; }
  .page-hero { min-height: 320px; }
  .page-hero__title { font-size: 44px; }
}

@media (max-width: 600px) {
  .page-content__inner { padding: 36px 16px 56px; }
  .page-hero { min-height: 240px; }
  .page-hero__title { font-size: 32px; }
  .rte h2 { font-size: 24px; }
  .rte p { font-size: 15px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.page",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image"
    }
  ]
}
{% endschema %}
