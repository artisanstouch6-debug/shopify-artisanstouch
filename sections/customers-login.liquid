<!-- ── Customer Login ──────────────────────────────── -->
<style>
  body.template-customers-login,
  body.template-customers-register {
    background: #fff7f0;
    padding-top: 0 !important;
  }
</style>

<div class="cl-page">
  <div class="cl-container">

    <!-- Left: jewellery photo card -->
    <div class="cl-photo">
      {%- if section.settings.left_image != blank -%}
        {{ section.settings.left_image | image_url: width: 900 | image_tag: class: 'cl-photo__img', loading: 'eager', alt: '' }}
      {%- else -%}
        <img src="{{ 'login-jewelry.jpg' | asset_url }}" alt="" class="cl-photo__img" loading="eager">
      {%- endif -%}
    </div>

    <!-- Right: form column -->
    <div class="cl-right">

      <!-- Back to Home -->
      <a href="{{ routes.root_url }}" class="cl-back">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M10 12L6 8L10 4" stroke="#111" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Back to Home
      </a>

      <!-- White card -->
      <div class="cl-card">

        <!-- Logo -->
        <div class="cl-logo-wrap">
          {%- if section.settings.logo != blank -%}
            {{ section.settings.logo | image_url: width: 220 | image_tag: class: 'cl-logo', alt: shop.name }}
          {%- else -%}
            <img src="{{ 'at-logo.png' | asset_url }}" alt="{{ shop.name }}" class="cl-logo">
          {%- endif -%}
        </div>

        <!-- Login view -->
        <div class="cl-view" id="cl-view-login">

          <div class="cl-headings">
            <h1 class="cl-title">Sign in</h1>
            <p class="cl-subtitle">Welcome back! Please sign in to your account.</p>
          </div>

          {%- form 'customer_login', id: 'cl-login-form' -%}
            {%- if form.errors -%}
              <div class="cl-errors" role="alert">
                {%- for error in form.errors -%}
                  <p>{{ form.errors.messages[error] }}</p>
                {%- endfor -%}
              </div>
            {%- endif -%}

            <div class="cl-fields">

              <div class="cl-field">
                <label class="cl-label" for="cl-email">Email Address</label>
                <input
                  class="cl-input"
                  type="email"
                  name="customer[email]"
                  id="cl-email"
                  autocomplete="email"
                  autocapitalize="off"
                  placeholder="jhonsmith@gmail.com"
                  value="{{ form.email }}"
                  required>
              </div>

              <div class="cl-field">
                <label class="cl-label" for="cl-password">Password</label>
                <div class="cl-pw-wrap">
                  <input
                    class="cl-input"
                    type="password"
                    name="customer[password]"
                    id="cl-password"
                    autocomplete="current-password"
                    placeholder="***********"
                    required>
                  <button type="button" class="cl-pw-toggle" aria-label="Toggle password visibility" tabindex="-1">
                    <svg class="cl-eye cl-eye--show" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                    </svg>
                    <svg class="cl-eye cl-eye--hide" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                      <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                      <line x1="1" y1="1" x2="23" y2="23"/>
                    </svg>
                  </button>
                </div>
              </div>

            </div>

            <button type="button" class="cl-forgot" id="cl-forgot-btn">Forgot your password?</button>

            <button type="submit" class="cl-submit">Sign in</button>

          {%- endform -%}

          <p class="cl-register-row">
            Don't have an account?
            <a href="{{ routes.account_register_url }}" class="cl-register-link">Sign up</a>
          </p>

        </div>

        <!-- Recover password view (hidden) -->
        <div class="cl-view" id="cl-view-recover" style="display:none">

          <div class="cl-headings">
            <h1 class="cl-title">Reset Password</h1>
            <p class="cl-subtitle">We'll send a link to your email to reset your password.</p>
          </div>

          {%- form 'recover_customer_password', id: 'cl-recover-form' -%}
            {%- if form.posted_successfully? -%}
              <div class="cl-success" role="alert">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Check your email for a reset link.
              </div>
            {%- else -%}
              {%- if form.errors -%}
                <div class="cl-errors" role="alert">
                  {%- for error in form.errors -%}<p>{{ form.errors.messages[error] }}</p>{%- endfor -%}
                </div>
              {%- endif -%}
              <div class="cl-fields">
                <div class="cl-field">
                  <label class="cl-label" for="cl-recover-email">Email Address</label>
                  <input class="cl-input" type="email" name="email" id="cl-recover-email" autocomplete="email" placeholder="jhonsmith@gmail.com" required>
                </div>
              </div>
              <button type="submit" class="cl-submit">Send Reset Link</button>
            {%- endif -%}
          {%- endform -%}

          <p class="cl-register-row">
            <button type="button" class="cl-back-btn" id="cl-back-btn">Back to Sign in</button>
          </p>

        </div>

      </div><!-- /cl-card -->
    </div><!-- /cl-right -->
  </div><!-- /cl-container -->
</div><!-- /cl-page -->

{% javascript %}
(function () {
  var loginView   = document.getElementById('cl-view-login');
  var recoverView = document.getElementById('cl-view-recover');
  var forgotBtn   = document.getElementById('cl-forgot-btn');
  var backBtn     = document.getElementById('cl-back-btn');
  var pwInput     = document.getElementById('cl-password');
  var pwToggle    = document.querySelector('.cl-pw-toggle');

  if (forgotBtn) {
    forgotBtn.addEventListener('click', function () {
      loginView.style.display   = 'none';
      recoverView.style.display = '';
    });
  }

  if (backBtn) {
    backBtn.addEventListener('click', function () {
      recoverView.style.display = 'none';
      loginView.style.display   = '';
    });
  }

  if (pwToggle && pwInput) {
    pwToggle.addEventListener('click', function () {
      var show = pwInput.type === 'password';
      pwInput.type = show ? 'text' : 'password';
      document.querySelector('.cl-eye--show').style.display = show ? 'none' : '';
      document.querySelector('.cl-eye--hide').style.display = show ? '' : 'none';
    });
  }

  if (window.location.hash === '#recover') {
    if (loginView)   loginView.style.display   = 'none';
    if (recoverView) recoverView.style.display  = '';
  }
})();
{% endjavascript %}

{% stylesheet %}
/* ── Page shell ─────────────────────────────────────── */
.cl-page {
  min-height: 100vh;
  background: #fff7f0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 40px;
  box-sizing: border-box;
}

/* ── Two-column container ──────────────────────────── */
.cl-container {
  display: flex;
  align-items: center;
  gap: 20px;
  width: 100%;
  max-width: 1200px;
}

/* ── Left photo card ────────────────────────────────── */
.cl-photo {
  flex: 0 0 490px;
  height: 700px;
  border-radius: 32px;
  overflow: hidden;
  flex-shrink: 0;
}

.cl-photo__img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

/* ── Right column ───────────────────────────────────── */
.cl-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12px;
  min-width: 0;
}

/* ── Back link ──────────────────────────────────────── */
.cl-back {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-body);
  font-size: 12px;
  color: #111;
  text-decoration: none;
  transition: opacity 0.2s;
}

.cl-back:hover { opacity: 0.65; }

/* ── White form card ────────────────────────────────── */
.cl-card {
  background: #fff;
  border-radius: 14px;
  padding: 48px 32px;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32px;
}

/* ── Logo ───────────────────────────────────────────── */
.cl-logo-wrap {
  display: flex;
  justify-content: center;
  width: 100%;
}

.cl-logo {
  height: 72px;
  width: auto;
  display: block;
  object-fit: contain;
}

/* ── Views (login / recover) ────────────────────────── */
.cl-view {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* ── Headings ───────────────────────────────────────── */
.cl-headings {
  display: flex;
  flex-direction: column;
  gap: 8px;
  text-align: center;
  margin-bottom: 20px;
}

.cl-title {
  font-family: var(--font-heading);
  font-size: 36px;
  font-weight: 700;
  color: #000;
  margin: 0;
  line-height: 1.1;
  letter-spacing: -0.02em;
}

.cl-subtitle {
  font-family: var(--font-body);
  font-size: 16px;
  color: #808080;
  margin: 0;
  line-height: 1.6;
}

/* ── Fields ─────────────────────────────────────────── */
.cl-fields {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 4px;
}

.cl-field {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.cl-label {
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 500;
  color: #000;
  line-height: 1.6;
}

.cl-input {
  width: 100%;
  height: 46px;
  background: #f5f5f5;
  border: 0.5px solid #434343;
  border-radius: 8px;
  padding: 0 44px 0 14px;
  font-family: var(--font-body);
  font-size: 14px;
  color: #111;
  box-sizing: border-box;
  outline: none;
  -webkit-appearance: none;
  appearance: none;
  transition: border-color 0.2s;
}

.cl-input:not(.cl-pw-wrap .cl-input) { padding-right: 14px; }

.cl-input:focus { border-color: #ff9696; }

.cl-input::placeholder { color: #808080; }

/* ── Password wrap ──────────────────────────────────── */
.cl-pw-wrap {
  position: relative;
}

.cl-pw-toggle {
  position: absolute;
  right: 12px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  line-height: 0;
  display: flex;
  align-items: center;
}

/* ── Forgot password ────────────────────────────────── */
.cl-forgot {
  background: none;
  border: none;
  padding: 0;
  font-family: var(--font-body);
  font-size: 16px;
  color: #3b80ff;
  cursor: pointer;
  text-align: left;
  margin-top: 8px;
  margin-bottom: 0;
  line-height: 2;
}

/* ── Submit button ──────────────────────────────────── */
.cl-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 46px;
  background: #ff9696;
  border: none;
  border-radius: 8px;
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 600;
  color: #fff;
  cursor: pointer;
  margin-top: 8px;
  transition: opacity 0.2s;
  letter-spacing: 0.01em;
}

.cl-submit:hover { opacity: 0.85; }

/* ── Register row ───────────────────────────────────── */
.cl-register-row {
  font-family: var(--font-body);
  font-size: 14px;
  color: #808080;
  text-align: center;
  margin: 20px 0 0;
}

.cl-register-link {
  color: #3b80ff;
  text-decoration: none;
  font-weight: 500;
}

.cl-register-link:hover { text-decoration: underline; }

/* ── Back to sign-in button ─────────────────────────── */
.cl-back-btn {
  background: none;
  border: none;
  padding: 0;
  font-family: var(--font-body);
  font-size: 14px;
  color: #3b80ff;
  cursor: pointer;
  font-weight: 500;
}

.cl-back-btn:hover { text-decoration: underline; }

/* ── Error / success states ─────────────────────────── */
.cl-errors {
  background: rgba(220,38,38,0.07);
  border: 1px solid rgba(220,38,38,0.22);
  border-radius: 8px;
  padding: 10px 14px;
  margin-bottom: 16px;
}

.cl-errors p {
  font-family: var(--font-body);
  font-size: 13px;
  color: #dc2626;
  margin: 0;
}

.cl-errors p + p { margin-top: 4px; }

.cl-success {
  display: flex;
  align-items: center;
  gap: 10px;
  background: rgba(34,197,94,0.07);
  border: 1px solid rgba(34,197,94,0.28);
  border-radius: 8px;
  padding: 12px 14px;
  font-family: var(--font-body);
  font-size: 14px;
  color: #166534;
  margin-bottom: 16px;
}

/* ── Responsive ─────────────────────────────────────── */
@media (max-width: 1100px) {
  .cl-photo { flex: 0 0 420px; height: 600px; }
  .cl-card { padding: 40px 28px; }
}

@media (max-width: 900px) {
  .cl-photo { flex: 0 0 340px; height: 500px; }
  .cl-page { padding: 40px 24px; }
}

@media (max-width: 768px) {
  .cl-container { flex-direction: column; align-items: stretch; gap: 24px; }
  .cl-photo { flex: none; width: 100%; height: 280px; }
  .cl-card { padding: 36px 24px; }
  .cl-title { font-size: 28px; }
  .cl-subtitle { font-size: 15px; }
}

@media (max-width: 480px) {
  .cl-page { padding: 24px 16px 48px; }
  .cl-photo { height: 220px; border-radius: 20px; }
  .cl-card { padding: 28px 20px; border-radius: 12px; }
  .cl-title { font-size: 24px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Customer Login",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left jewellery photo"
    }
  ]
}
{% endschema %}
