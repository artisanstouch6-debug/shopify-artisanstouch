<div class="feature-story full-width">
  <div class="feature-story__text">
    <h2 class="feature-story__heading">{{ section.settings.heading }}</h2>
    <p class="feature-story__desc">{{ section.settings.description }}</p>
    <a href="{{ section.settings.button_url }}" class="at-btn">
      {{ section.settings.button_label }}
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path d="M5 12H19M12 5L19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>

  <div class="feature-story__visual">
    <div class="feature-story__arch-glow"></div>
    <div class="feature-story__arch">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 452, height: 622, crop: 'center' | image_tag: class: 'feature-story__arch-img', loading: 'lazy', alt: section.settings.heading }}
      {% else %}
        <img src="{{ 'feature-story-arch.jpg' | asset_url }}" alt="{{ section.settings.heading }}" class="feature-story__arch-img">
      {% endif %}
    </div>
    <div class="feature-story__circle">
      {% if section.settings.circle_image %}
        {{ section.settings.circle_image | image_url: width: 316, height: 316, crop: 'center' | image_tag: class: 'feature-story__circle-img', loading: 'lazy', alt: '' }}
      {% else %}
        <img src="{{ 'feature-story-circle.jpg' | asset_url }}" alt="" class="feature-story__circle-img">
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .feature-story {
    grid-column: 1 / -1;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 60px 120px;
    max-width: 1440px;
    margin: 0 auto;
    gap: 60px;
  }

  .feature-story__text {
    display: flex;
    flex-direction: column;
    gap: 48px;
    flex: 1;
    min-width: 0;
    max-width: 480px;
  }

  .feature-story__heading {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 700;
    color: #000;
    margin: 0;
    line-height: 1.2;
  }

  .feature-story__desc {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--gray, #828282);
    margin: 0;
    line-height: 1.7;
  }

  .feature-story__visual {
    position: relative;
    width: min(588px, 46vw);
    aspect-ratio: 588 / 656;
    flex-shrink: 0;
  }

  .feature-story__arch-glow {
    position: absolute;
    right: -10px;
    top: -10px;
    width: calc(76.9% + 20px);
    height: calc(94.8% + 20px);
    border-radius: 50% 50% 16px 16px;
    background:
      radial-gradient(ellipse at 85% 25%, rgba(255, 182, 193, 0.8) 0%, transparent 50%),
      radial-gradient(ellipse at 15% 65%, rgba(255, 220, 100, 0.7) 0%, transparent 50%);
    filter: blur(28px);
    z-index: 0;
    pointer-events: none;
  }

  .feature-story__arch {
    position: absolute;
    right: 0;
    top: 0;
    width: 76.9%;
    height: 94.8%;
    border-radius: 50% 50% 12px 12px;
    overflow: hidden;
    z-index: 1;
  }

  .feature-story__arch-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .feature-story__circle {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 53.7%;
    height: 48.2%;
    border-radius: 50%;
    overflow: hidden;
    z-index: 2;
    box-shadow: 0 0 0 6px #fff;
  }

  .feature-story__circle-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* 2-column: reduce padding at 1380px */
  @media (max-width: 1380px) {
    .feature-story { padding: 60px 60px; gap: 40px; }
  }

  /* 2-column: tighter padding at 1100px, still side-by-side */
  @media (max-width: 1100px) {
    .feature-story { padding: 52px 40px; gap: 32px; }
    .feature-story__heading { font-size: 38px; }
    .feature-story__text { gap: 32px; }
  }

  /* 2-column: minimum padding at 900px, still side-by-side */
  @media (max-width: 900px) {
    .feature-story { padding: 48px 28px; gap: 24px; }
    .feature-story__heading { font-size: 30px; }
    .feature-story__text { gap: 24px; }
    .feature-story__desc { font-size: 15px; }
  }

  /* Stack to column only below 768px */
  @media (max-width: 768px) {
    .feature-story {
      padding: 48px 24px;
      flex-direction: column;
      align-items: flex-start;
      gap: 40px;
    }
    .feature-story__heading { font-size: 32px; }
    .feature-story__text { max-width: 100%; gap: 28px; }
    .feature-story__visual {
      width: 100%;
      max-width: 480px;
      align-self: center;
    }
  }

  @media (max-width: 480px) {
    .feature-story { padding: 40px 20px; gap: 32px; }
    .feature-story__heading { font-size: 26px; }
    .feature-story__text { gap: 20px; }
    .feature-story__visual { max-width: 100%; }
  }

  @media (max-width: 375px) {
    .feature-story { padding: 36px 16px; }
    .feature-story__heading { font-size: 24px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Feature Story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Creates Lasting Memories of Each occasion"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Cras consectetur, massa sed viverra aliquet, sem justo finibus eros, semper suscipit tellus neque sed dui."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main (arch) image"
    },
    {
      "type": "image_picker",
      "id": "circle_image",
      "label": "Circle image (bottom left)"
    }
  ],
  "presets": [
    {
      "name": "Feature Story"
    }
  ]
}
{% endschema %}
