<div class="feature-story full-width">
  <div class="feature-story__text">
    <h2 class="feature-story__heading">{{ section.settings.heading }}</h2>
    <p class="feature-story__desc">{{ section.settings.description }}</p>
    <a href="{{ section.settings.button_url }}" class="at-btn">
      {{ section.settings.button_label }}
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path d="M5 12H19M12 5L19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>

  <div class="feature-story__visual">
    <div class="feature-story__arch">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 452, height: 622, crop: 'center' | image_tag: class: 'feature-story__arch-img', loading: 'lazy', alt: section.settings.heading }}
      {% else %}
        <img src="{{ 'feature-story-arch.jpg' | asset_url }}" alt="{{ section.settings.heading }}" class="feature-story__arch-img">
      {% endif %}
    </div>
    <div class="feature-story__circle">
      {% if section.settings.circle_image %}
        {{ section.settings.circle_image | image_url: width: 316, height: 316, crop: 'center' | image_tag: class: 'feature-story__circle-img', loading: 'lazy', alt: '' }}
      {% else %}
        <img src="{{ 'feature-story-circle.jpg' | asset_url }}" alt="" class="feature-story__circle-img">
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .feature-story {
    grid-column: 1 / -1;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 60px 120px;
    max-width: 1440px;
    margin: 0 auto;
    gap: 60px;
  }

  .feature-story__text {
    display: flex;
    flex-direction: column;
    gap: 48px;
    max-width: 509px;
    flex-shrink: 0;
  }

  .feature-story__heading {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 700;
    color: #000;
    margin: 0;
    line-height: 1.2;
  }

  .feature-story__desc {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--gray, #828282);
    margin: 0;
    line-height: 1.7;
  }

  .feature-story__visual {
    position: relative;
    width: 588px;
    height: 656px;
    flex-shrink: 0;
  }

  .feature-story__arch {
    position: absolute;
    right: 0;
    top: 0;
    width: 452px;
    height: 622px;
    border-radius: 243px 243px 12px 12px;
    overflow: hidden;
  }

  .feature-story__arch-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .feature-story__arch-placeholder {
    background: linear-gradient(135deg, #f5e6da, #e8c9a0);
  }

  .feature-story__circle {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 316px;
    height: 316px;
    border-radius: 50%;
    overflow: hidden;
  }

  .feature-story__circle-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .feature-story__circle-placeholder {
    background: linear-gradient(135deg, #ffc4c4, #ff9696);
  }

  @media (max-width: 1100px) {
    .feature-story {
      padding: 48px 48px;
      flex-direction: column;
    }
    .feature-story__visual {
      width: 100%;
      max-width: 480px;
      height: 480px;
    }
    .feature-story__arch {
      width: 320px;
      height: 440px;
      border-radius: 160px 160px 12px 12px;
    }
    .feature-story__circle {
      width: 200px;
      height: 200px;
    }
  }

  @media (max-width: 768px) {
    .feature-story { padding: 40px 24px; }
    .feature-story__heading { font-size: 32px; }
    .feature-story__text { max-width: 100%; gap: 32px; }
    .feature-story__visual { height: 360px; max-width: 100%; }
    .feature-story__arch { width: 240px; height: 320px; border-radius: 120px 120px 12px 12px; }
    .feature-story__circle { width: 150px; height: 150px; }
  }

  @media (max-width: 480px) {
    .feature-story__heading { font-size: 28px; }
    .feature-story__visual { height: 280px; }
    .feature-story__arch { width: 185px; height: 248px; border-radius: 92px 92px 12px 12px; }
    .feature-story__circle { width: 120px; height: 120px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Feature Story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Creates Lasting Memories of Each occasion"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Cras consectetur, massa sed viverra aliquet, sem justo finibus eros, semper suscipit tellus neque sed dui."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main (arch) image"
    },
    {
      "type": "image_picker",
      "id": "circle_image",
      "label": "Circle image (bottom left)"
    }
  ],
  "presets": [
    {
      "name": "Feature Story"
    }
  ]
}
{% endschema %}
