<!-- ── About Us Page ──────────────────────────────── -->

<!-- Remove body padding so hero starts at top -->
<style>
  body.template-page { padding-top: 0 !important; }
</style>

<!-- ── Hero Banner ───────────────────────────────── -->
<section class="au-hero full-width">
  {%- if section.settings.hero_image -%}
    {{ section.settings.hero_image | image_url: width: 2000 | image_tag: class: 'au-hero__bg', loading: 'eager', fetchpriority: 'high', alt: '' }}
  {%- else -%}
    <img src="{{ 'about-hero.jpg' | asset_url }}" alt="" class="au-hero__bg" loading="eager">
  {%- endif -%}
  <div class="au-hero__overlay"></div>
  <div class="au-hero__text">
    <h1 class="au-hero__title">{{ section.settings.hero_heading | default: 'About Us' }}</h1>
  </div>
</section>

<!-- ── Story Section ─────────────────────────────── -->
<section class="au-story full-width">
  <div class="au-story__inner">
    <div class="au-story__text">
      {%- if section.settings.story_text != blank -%}
        {{ section.settings.story_text }}
      {%- else -%}
        <p>Founded in 2018, Artisans Touch was born from a passion for creating timeless pieces that celebrate life's most precious moments. Each piece is carefully handcrafted by skilled artisans who pour their hearts into every detail.</p>
        <p>We believe that jewellery is more than just an accessory — it's a way to express your unique style and commemorate the moments that matter most. From everyday costume pieces to bespoke bridal collections, we're committed to crafting jewellery that will be cherished for generations.</p>
        <p>Our commitment to ethical sourcing and sustainable practices ensures that every piece you wear reflects not only beauty, but also values that matter.</p>
      {%- endif -%}
    </div>
    <div class="au-story__img-wrap">
      {%- if section.settings.story_image -%}
        {{ section.settings.story_image | image_url: width: 980 | image_tag: class: 'au-story__img', loading: 'lazy', alt: section.settings.story_image.alt | default: shop.name }}
      {%- else -%}
        <img src="{{ 'about-story.jpg' | asset_url }}" alt="{{ shop.name }}" class="au-story__img" loading="lazy">
      {%- endif -%}
    </div>
  </div>
</section>

<!-- ── Quote + Pillars Section ───────────────────── -->
<section class="au-pillars full-width">
  <div class="au-pillars__inner">
    <blockquote class="au-pillars__quote">
      {%- if section.settings.quote != blank -%}
        {{ section.settings.quote }}
      {%- else -%}
        &ldquo;Every Piece tells a story, crafted with intention and care.&rdquo;
      {%- endif -%}
    </blockquote>
    <div class="au-pillars__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'pillar' -%}
          <div class="au-pillar" {{ block.shopify_attributes }}>
            <h3 class="au-pillar__title">{{ block.settings.title }}</h3>
            <p class="au-pillar__body">{{ block.settings.body }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
/* ── Hero ────────────────────────────────────────── */
.au-hero {
  position: relative;
  height: 55vh;
  min-height: 320px;
  max-height: 520px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.au-hero__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

.au-hero__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.40);
}

.au-hero__text {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 0 40px;
}

.au-hero__title {
  font-family: var(--font-heading);
  font-size: 64px;
  font-weight: 400;
  color: #fff;
  margin: 0;
  line-height: 1.1;
}

/* ── Story Section ───────────────────────────────── */
.au-story {
  background: #fff8f8;
}

.au-story__inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 80px 120px;
  display: grid;
  grid-template-columns: 1fr 487px;
  gap: 60px;
  align-items: start;
  box-sizing: border-box;
}

.au-story__text {
  font-family: var(--font-body);
  font-size: 20px;
  color: #000;
  line-height: 1.75;
}

.au-story__text p {
  margin: 0 0 24px;
}

.au-story__text p:last-child {
  margin-bottom: 0;
}

.au-story__img-wrap {
  border-radius: 12px;
  overflow: hidden;
  flex-shrink: 0;
}

.au-story__img {
  display: block;
  width: 100%;
  height: 512px;
  object-fit: cover;
}

/* ── Pillars Section ─────────────────────────────── */
.au-pillars {
  background: #fff8f8;
}

.au-pillars__inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 48px 120px 96px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 48px;
  box-sizing: border-box;
}

.au-pillars__quote {
  font-family: var(--font-heading);
  font-size: 32px;
  font-weight: 600;
  color: #000;
  text-align: center;
  margin: 0;
  line-height: 1.4;
}

.au-pillars__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  width: 100%;
}

.au-pillar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  text-align: center;
}

.au-pillar__title {
  font-family: var(--font-heading);
  font-size: 24px;
  font-weight: 600;
  color: #000;
  margin: 0;
}

.au-pillar__body {
  font-family: var(--font-body);
  font-size: 20px;
  color: #000;
  margin: 0;
  line-height: 1.6;
}

/* ── Responsive ──────────────────────────────────── */
@media (max-width: 1200px) {
  .au-story__inner { padding: 64px 80px; gap: 40px; }
  .au-pillars__inner { padding: 40px 80px 72px; }
  .au-hero__title { font-size: 52px; }
}

@media (max-width: 960px) {
  .au-hero { height: 45vh; min-height: 240px; max-height: 360px; }
  .au-hero__title { font-size: 38px; }
  .au-story__inner {
    grid-template-columns: 1fr;
    padding: 48px 40px;
    gap: 32px;
  }
  .au-story__img { height: 360px; }
  .au-pillars__inner { padding: 36px 40px 60px; }
  .au-pillars__quote { font-size: 26px; }
  .au-pillars__grid { grid-template-columns: 1fr; gap: 32px; }
}

@media (max-width: 600px) {
  .au-hero { height: 40vh; min-height: 200px; max-height: 280px; }
  .au-hero__title { font-size: 28px; }
  .au-story__inner { padding: 36px 24px; }
  .au-story__text { font-size: 16px; }
  .au-story__img { height: 260px; }
  .au-pillars__inner { padding: 28px 24px 52px; gap: 32px; }
  .au-pillars__quote { font-size: 20px; }
  .au-pillar__title { font-size: 20px; }
  .au-pillar__body { font-size: 16px; }
}
{% endstylesheet %}

