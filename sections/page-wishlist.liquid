{% comment %} Dedicated Wishlist page — reads from localStorage key: artisans_wishlist {% endcomment %}

<style>
  body.template-page { padding-top: 0 !important; }
</style>

<!-- ── Hero ─────────────────────────────────────────── -->
<section class="wl-hero full-width">
  {%- if section.settings.hero_image != blank -%}
    {{ section.settings.hero_image | image_url: width: 1800 | image_tag: class: 'wl-hero__bg', loading: 'eager', fetchpriority: 'high', alt: '' }}
  {%- else -%}
    <img src="{{ 'hero-bg.jpg' | asset_url }}" alt="" class="wl-hero__bg" loading="eager">
  {%- endif -%}
  <div class="wl-hero__overlay"></div>
  <div class="wl-hero__text">
    <h1 class="wl-hero__title">{{ section.settings.hero_heading | default: 'My Wishlist' }}</h1>
  </div>
</section>

<!-- ── Wishlist Body ──────────────────────────────────── -->
<section class="wl-body full-width">
  <div class="wl-inner">

    <div class="wl-header">
      <p class="wl-count" id="wl-count">Loading…</p>
      <button class="wl-clear-btn" id="wl-clear-btn">Clear All</button>
    </div>

    <!-- Empty state -->
    <div class="wl-empty" id="wl-empty" style="display:none;">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12.62 20.81C12.28 20.93 11.72 20.93 11.38 20.81C8.48 19.82 2 15.69 2 8.69C2 5.6 4.49 3.1 7.56 3.1C9.38 3.1 10.99 3.98 12 5.34C13.01 3.98 14.63 3.1 16.44 3.1C19.51 3.1 22 5.6 22 8.69C22 15.69 15.52 19.82 12.62 20.81Z" stroke="#e0c8c8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="wl-empty__title">Your wishlist is empty</p>
      <p class="wl-empty__sub">Save items you love and find them here.</p>
      <a href="{{ routes.all_products_collection_url }}" class="wl-shop-btn">Shop Now</a>
    </div>

    <!-- Grid -->
    <div class="wl-grid" id="wl-grid"></div>

  </div>
</section>

<script>
(function () {
  var WK = 'artisans_wishlist';

  function getList() {
    try { return JSON.parse(localStorage.getItem(WK) || '[]'); } catch(e) { return []; }
  }
  function saveList(arr) {
    localStorage.setItem(WK, JSON.stringify(arr));
  }

  var grid    = document.getElementById('wl-grid');
  var empty   = document.getElementById('wl-empty');
  var countEl = document.getElementById('wl-count');
  var clearBtn = document.getElementById('wl-clear-btn');

  function render() {
    var list = getList();
    grid.innerHTML = '';

    if (list.length === 0) {
      empty.style.display = 'flex';
      grid.style.display  = 'none';
      countEl.textContent = '0 items';
      clearBtn.style.display = 'none';
      return;
    }

    empty.style.display = 'none';
    grid.style.display  = 'grid';
    clearBtn.style.display = 'inline-flex';
    countEl.textContent = list.length + (list.length === 1 ? ' item' : ' items');

    list.forEach(function(item) {
      var card = document.createElement('div');
      card.className = 'wl-card';
      card.dataset.id = item.id;

      var imgHtml = item.image
        ? '<img src="' + item.image + '" alt="' + (item.title || '') + '" class="wl-card__img" loading="lazy">'
        : '<div class="wl-card__img wl-card__img--empty"></div>';

      card.innerHTML =
        '<a href="' + (item.url || '#') + '" class="wl-card__img-wrap">' + imgHtml + '</a>' +
        '<div class="wl-card__info">' +
          '<a href="' + (item.url || '#') + '" class="wl-card__title">' + (item.title || '') + '</a>' +
          '<p class="wl-card__price">' + (item.price || '') + '</p>' +
          '<div class="wl-card__actions">' +
            '<a href="' + (item.url || '#') + '" class="wl-card__view-btn">View Product</a>' +
            '<button class="wl-card__remove-btn" data-id="' + item.id + '" aria-label="Remove from wishlist">' +
              '<svg width="20" height="20" viewBox="0 0 24 24" fill="#ff4d4d" xmlns="http://www.w3.org/2000/svg"><path d="M12.62 20.81C12.28 20.93 11.72 20.93 11.38 20.81C8.48 19.82 2 15.69 2 8.69C2 5.6 4.49 3.1 7.56 3.1C9.38 3.1 10.99 3.98 12 5.34C13.01 3.98 14.63 3.1 16.44 3.1C19.51 3.1 22 5.6 22 8.69C22 15.69 15.52 19.82 12.62 20.81Z" stroke="#ff4d4d" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>' +
            '</button>' +
          '</div>' +
        '</div>';

      grid.appendChild(card);
    });

    grid.querySelectorAll('.wl-card__remove-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = btn.dataset.id;
        saveList(getList().filter(function(i) { return String(i.id) !== String(id); }));
        render();
      });
    });
  }

  if (clearBtn) {
    clearBtn.addEventListener('click', function() {
      saveList([]);
      render();
    });
  }

  render();
})();
</script>

{% stylesheet %}
/* ── Hero ────────────────────────────────────────── */
.wl-hero {
  position: relative;
  height: 55vh;
  min-height: 320px;
  max-height: 500px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.wl-hero__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

.wl-hero__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.48);
}

.wl-hero__text {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 0 40px;
}

.wl-hero__title {
  font-family: var(--font-heading);
  font-size: 64px;
  font-weight: 400;
  color: #fff;
  margin: 0;
  line-height: 1.1;
}

/* ── Body ────────────────────────────────────────── */
.wl-body {
  background: #fff8f8;
  min-height: 60vh;
}

.wl-inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 48px 120px 96px;
  box-sizing: border-box;
}

/* ── Header row ──────────────────────────────────── */
.wl-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 36px;
}

.wl-count {
  font-family: var(--font-body);
  font-size: 15px;
  color: #888;
  margin: 0;
}

.wl-clear-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: none;
  border: 1.5px solid #e0e0e0;
  border-radius: 20px;
  padding: 8px 20px;
  font-family: var(--font-body);
  font-size: 13px;
  color: #555;
  cursor: pointer;
  transition: border-color 0.2s, color 0.2s;
}

.wl-clear-btn:hover {
  border-color: #ff4d4d;
  color: #ff4d4d;
}

/* ── Empty state ─────────────────────────────────── */
.wl-empty {
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  padding: 80px 20px;
  text-align: center;
}

.wl-empty__title {
  font-family: var(--font-heading);
  font-size: 28px;
  color: #111;
  margin: 0;
}

.wl-empty__sub {
  font-family: var(--font-body);
  font-size: 15px;
  color: #888;
  margin: 0;
}

.wl-shop-btn {
  display: inline-flex;
  align-items: center;
  height: 48px;
  padding: 0 32px;
  background: var(--coral-pink, #ff9696);
  border-radius: 24px;
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 600;
  color: #fff;
  text-decoration: none;
  transition: opacity 0.2s;
  margin-top: 8px;
}

.wl-shop-btn:hover { opacity: 0.85; }

/* ── Grid ────────────────────────────────────────── */
.wl-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

/* ── Card ────────────────────────────────────────── */
.wl-card {
  display: flex;
  flex-direction: column;
  gap: 14px;
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  transition: box-shadow 0.2s;
}

.wl-card:hover {
  box-shadow: 0 6px 24px rgba(0,0,0,0.10);
}

.wl-card__img-wrap {
  display: block;
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #f0ebe8;
}

.wl-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s;
}

.wl-card__img-wrap:hover .wl-card__img { transform: scale(1.04); }

.wl-card__img--empty {
  background: #f0ebe8;
}

.wl-card__info {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 0 16px 16px;
}

.wl-card__title {
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 600;
  color: #111;
  text-decoration: none;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.wl-card__title:hover { color: var(--coral-pink, #ff9696); }

.wl-card__price {
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 700;
  color: #111;
  margin: 0;
}

.wl-card__actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-top: 4px;
}

.wl-card__view-btn {
  display: inline-flex;
  align-items: center;
  height: 38px;
  padding: 0 18px;
  background: var(--coral-pink, #ff9696);
  border-radius: 19px;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 600;
  color: #fff;
  text-decoration: none;
  transition: opacity 0.2s;
  flex: 1;
  justify-content: center;
}

.wl-card__view-btn:hover { opacity: 0.85; }

.wl-card__remove-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  transition: background 0.2s;
}

.wl-card__remove-btn:hover { background: #fff0f0; }

/* ── Responsive ──────────────────────────────────── */
@media (max-width: 1200px) {
  .wl-inner { padding: 40px 60px 72px; }
}

@media (max-width: 960px) {
  .wl-hero { height: 45vh; min-height: 260px; max-height: 380px; }
  .wl-hero__title { font-size: 40px; }
  .wl-inner { padding: 36px 32px 64px; }
  .wl-grid { grid-template-columns: repeat(3, 1fr); gap: 20px; }
}

@media (max-width: 700px) {
  .wl-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
}

@media (max-width: 600px) {
  .wl-hero { height: 40vh; min-height: 220px; max-height: 300px; }
  .wl-hero__title { font-size: 28px; }
  .wl-inner { padding: 24px 16px 52px; }
  .wl-card__title { font-size: 13px; }
  .wl-card__price { font-size: 13px; }
  .wl-card__view-btn { font-size: 12px; padding: 0 12px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Wishlist",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero heading",
      "default": "My Wishlist"
    }
  ],
  "presets": [
    {
      "name": "Wishlist"
    }
  ]
}
{% endschema %}
