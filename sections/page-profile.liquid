{% comment %} Wishlist page — shows saved items from localStorage {% endcomment %}

<style>body.template-page { padding-top: 0 !important; }</style>

<!-- ── Hero ─────────────────────────────────────────── -->
<section class="wlp-hero full-width">
  {%- if section.settings.hero_image != blank -%}
    {{ section.settings.hero_image | image_url: width: 1800 | image_tag: class: 'wlp-hero__bg', loading: 'eager', fetchpriority: 'high', alt: '' }}
  {%- else -%}
    <img src="{{ 'hero-bg.jpg' | asset_url }}" alt="" class="wlp-hero__bg" loading="eager">
  {%- endif -%}
  <div class="wlp-hero__overlay"></div>
  <div class="wlp-hero__text">
    <h1 class="wlp-hero__title">{{ section.settings.heading | default: 'My Wishlist' }}</h1>
  </div>
</section>

<!-- ── Wishlist Body ──────────────────────────────────── -->
<section class="wlp-body full-width">
  <div class="wlp-inner">

    <div class="wlp-toolbar">
      <p class="wlp-count" id="wlp-count"></p>
      <button class="wlp-clear" id="wlp-clear" style="display:none">Clear All</button>
    </div>

    <!-- Empty state -->
    <div class="wlp-empty" id="wlp-empty" style="display:none">
      <svg width="60" height="60" viewBox="0 0 24 24" fill="none">
        <path d="M12.62 20.81C12.28 20.93 11.72 20.93 11.38 20.81C8.48 19.82 2 15.69 2 8.69C2 5.6 4.49 3.1 7.56 3.1C9.38 3.1 10.99 3.98 12 5.34C13.01 3.98 14.63 3.1 16.44 3.1C19.51 3.1 22 5.6 22 8.69C22 15.69 15.52 19.82 12.62 20.81Z" stroke="#e0c0c0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="wlp-empty__title">Your wishlist is empty</p>
      <p class="wlp-empty__sub">Browse our collections and save items you love.</p>
      <a href="{{ routes.all_products_collection_url }}" class="wlp-shop-btn">Shop Now</a>
    </div>

    <!-- Grid -->
    <div class="wlp-grid" id="wlp-grid"></div>

  </div>
</section>

<script>
(function () {
  var WK = 'artisans_wishlist';
  var grid    = document.getElementById('wlp-grid');
  var empty   = document.getElementById('wlp-empty');
  var countEl = document.getElementById('wlp-count');
  var clearBtn = document.getElementById('wlp-clear');

  function getList() {
    try { return JSON.parse(localStorage.getItem(WK) || '[]'); } catch(e) { return []; }
  }
  function saveList(arr) { localStorage.setItem(WK, JSON.stringify(arr)); }

  function render() {
    var list = getList();
    grid.innerHTML = '';

    if (list.length === 0) {
      empty.style.display  = 'flex';
      grid.style.display   = 'none';
      clearBtn.style.display = 'none';
      countEl.textContent  = '0 saved items';
      return;
    }

    empty.style.display  = 'none';
    grid.style.display   = 'grid';
    clearBtn.style.display = 'inline-flex';
    countEl.textContent  = list.length + (list.length === 1 ? ' saved item' : ' saved items');

    list.forEach(function(item) {
      var card = document.createElement('div');
      card.className = 'wlp-card';

      var imgHtml = item.image
        ? '<img src="' + item.image + '" alt="' + (item.title || '') + '" class="wlp-card__img" loading="lazy">'
        : '<div class="wlp-card__img wlp-card__img--empty"></div>';

      card.innerHTML =
        '<a href="' + (item.url || '#') + '" class="wlp-card__img-wrap">' + imgHtml + '</a>' +
        '<div class="wlp-card__body">' +
          '<a href="' + (item.url || '#') + '" class="wlp-card__title">' + (item.title || '') + '</a>' +
          '<p class="wlp-card__price">' + (item.price || '') + '</p>' +
          '<div class="wlp-card__foot">' +
            '<a href="' + (item.url || '#') + '" class="wlp-card__view">View Product</a>' +
            '<button class="wlp-card__remove" data-id="' + item.id + '" aria-label="Remove">' +
              '<svg width="20" height="20" viewBox="0 0 24 24" fill="#ff4d4d" stroke="#ff4d4d" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>' +
            '</button>' +
          '</div>' +
        '</div>';

      card.querySelector('.wlp-card__remove').addEventListener('click', function() {
        saveList(getList().filter(function(i) { return String(i.id) !== String(item.id); }));
        render();
      });

      grid.appendChild(card);
    });
  }

  clearBtn.addEventListener('click', function() { saveList([]); render(); });
  render();
})();
</script>

{% stylesheet %}
/* ── Hero ─────────────────────────────────────────── */
.wlp-hero {
  position: relative;
  height: 55vh;
  min-height: 320px;
  max-height: 500px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.wlp-hero__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}
.wlp-hero__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.48);
}
.wlp-hero__text {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 0 40px;
}
.wlp-hero__title {
  font-family: var(--font-heading);
  font-size: 64px;
  font-weight: 400;
  color: #fff;
  margin: 0;
  line-height: 1.1;
}

/* ── Body ─────────────────────────────────────────── */
.wlp-body { background: #fff8f8; min-height: 50vh; }
.wlp-inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 48px 120px 96px;
  box-sizing: border-box;
}

/* ── Toolbar ──────────────────────────────────────── */
.wlp-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32px;
}
.wlp-count {
  font-family: var(--font-body);
  font-size: 15px;
  color: #888;
  margin: 0;
}
.wlp-clear {
  display: inline-flex;
  align-items: center;
  background: none;
  border: 1.5px solid #e0e0e0;
  border-radius: 20px;
  padding: 8px 20px;
  font-family: var(--font-body);
  font-size: 13px;
  color: #555;
  cursor: pointer;
  transition: border-color 0.2s, color 0.2s;
}
.wlp-clear:hover { border-color: #ff4d4d; color: #ff4d4d; }

/* ── Empty state ──────────────────────────────────── */
.wlp-empty {
  flex-direction: column;
  align-items: center;
  gap: 14px;
  padding: 80px 20px;
  text-align: center;
}
.wlp-empty__title {
  font-family: var(--font-heading);
  font-size: 26px;
  color: #111;
  margin: 0;
}
.wlp-empty__sub {
  font-family: var(--font-body);
  font-size: 15px;
  color: #999;
  margin: 0;
}
.wlp-shop-btn {
  display: inline-flex;
  align-items: center;
  height: 46px;
  padding: 0 32px;
  background: var(--coral-pink, #ff9696);
  border-radius: 23px;
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 600;
  color: #fff;
  text-decoration: none;
  margin-top: 6px;
  transition: opacity 0.2s;
}
.wlp-shop-btn:hover { opacity: 0.85; }

/* ── Grid ─────────────────────────────────────────── */
.wlp-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

/* ── Card ─────────────────────────────────────────── */
.wlp-card {
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.2s;
}
.wlp-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.10); }

.wlp-card__img-wrap {
  display: block;
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #f0ebe8;
}
.wlp-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s;
}
.wlp-card__img-wrap:hover .wlp-card__img { transform: scale(1.04); }
.wlp-card__img--empty { width: 100%; height: 100%; background: #f0ebe8; }

.wlp-card__body {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 16px;
  flex: 1;
}
.wlp-card__title {
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 600;
  color: #111;
  text-decoration: none;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.wlp-card__title:hover { color: var(--coral-pink, #ff9696); }
.wlp-card__price {
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 700;
  color: #111;
  margin: 0;
}
.wlp-card__foot {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 6px;
}
.wlp-card__view {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 38px;
  background: var(--coral-pink, #ff9696);
  border-radius: 19px;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 600;
  color: #fff;
  text-decoration: none;
  transition: opacity 0.2s;
}
.wlp-card__view:hover { opacity: 0.85; }
.wlp-card__remove {
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
  display: flex;
  align-items: center;
  border-radius: 50%;
  transition: background 0.2s;
  flex-shrink: 0;
}
.wlp-card__remove:hover { background: #fff0f0; }

/* ── Responsive ───────────────────────────────────── */
@media (max-width: 1200px) {
  .wlp-inner { padding: 40px 60px 72px; }
}
@media (max-width: 960px) {
  .wlp-hero { height: 45vh; min-height: 260px; max-height: 380px; }
  .wlp-hero__title { font-size: 40px; }
  .wlp-inner { padding: 36px 32px 64px; }
  .wlp-grid { grid-template-columns: repeat(3, 1fr); gap: 18px; }
}
@media (max-width: 700px) {
  .wlp-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
}
@media (max-width: 600px) {
  .wlp-hero { height: 40vh; min-height: 220px; max-height: 300px; }
  .wlp-hero__title { font-size: 28px; }
  .wlp-inner { padding: 24px 16px 52px; }
  .wlp-card__title { font-size: 13px; }
  .wlp-card__price { font-size: 13px; }
  .wlp-card__view { font-size: 12px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Wishlist Page",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading",
      "default": "My Wishlist"
    }
  ],
  "presets": [{ "name": "Wishlist Page" }]
}
{% endschema %}
