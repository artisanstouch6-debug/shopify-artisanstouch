<div class="testimonials full-width">

  <div class="testimonials__heading-wrap">
    <h2 class="testimonials__heading">
      {{ section.settings.heading_prefix }}
      <span class="testimonials__heading-hl">
        {{ section.settings.heading_highlight }}
        <img src="{{ 'testimonial-heading-ellipse.svg' | asset_url }}" alt="" class="testimonials__heading-ellipse" aria-hidden="true">
      </span>
    </h2>
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="testimonials__slider" id="testimonials-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="testimonials__slide {% if forloop.first %}testimonials__slide--active{% endif %}" {{ block.shopify_attributes }}>

          <div class="testimonials__quote-wrap">
            <div class="testimonials__quote-mark" aria-hidden="true">
              <div class="testimonials__quote-icons">
                <img src="{{ 'testimonial-quote.svg' | asset_url }}" alt="" class="testimonials__quote-icon">
                <img src="{{ 'testimonial-quote.svg' | asset_url }}" alt="" class="testimonials__quote-icon">
              </div>
            </div>

            <div class="testimonials__content">
              <p class="testimonials__text">{{ block.settings.quote }}</p>
              <div class="testimonials__author">
                <p class="testimonials__author-name">{{ block.settings.author_name }}</p>
                <p class="testimonials__author-location">{{ block.settings.author_location }}</p>
              </div>
            </div>

            <div class="testimonials__controls">
              <button class="testimonials__nav-btn" aria-label="Previous review" data-testimonials-prev="{{ section.id }}">
                <svg width="50" height="50" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M16.6667 39.5834C16.6667 38.0375 15.1396 35.7292 13.5937 33.7917C11.6062 31.2917 9.23125 29.1105 6.50833 27.4459C4.46667 26.198 1.99167 25 0 25M0 25C1.99167 25 4.46875 23.8021 6.50833 22.5542C9.23125 20.8875 11.6062 18.7063 13.5937 16.2105C15.1396 14.2709 16.6667 11.9584 16.6667 10.4167M0 25H50" stroke="#FF9696" stroke-opacity="0.5" stroke-width="4"/>
                </svg>
              </button>
              <button class="testimonials__nav-btn" aria-label="Next review" data-testimonials-next="{{ section.id }}">
                <svg width="75" height="50" viewBox="0 0 75 50" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <g clip-path="url(#t-clip-{{ section.id }})">
                    <path d="M50 10.4166C50 11.9625 52.2906 14.2708 54.6094 16.2083C57.5906 18.7083 61.1531 20.8895 65.2375 22.5541C68.3 23.802 72.0125 25 75 25M75 25C72.0125 25 68.2969 26.1979 65.2375 27.4458C61.1531 29.1125 57.5906 31.2937 54.6094 33.7895C52.2906 35.7291 50 38.0416 50 39.5833M75 25H0" stroke="#FF9696" stroke-width="4"/>
                  </g>
                  <defs>
                    <clipPath id="t-clip-{{ section.id }}">
                      <rect width="50" height="75" fill="white" transform="matrix(0 1 -1 0 75 0)"/>
                    </clipPath>
                  </defs>
                </svg>
              </button>
            </div>
          </div>

          <div class="testimonials__portrait">
            {% if block.settings.author_image %}
              {{ block.settings.author_image | image_url: width: 245, height: 321, crop: 'center' | image_tag: class: 'testimonials__portrait-img', loading: 'lazy', alt: block.settings.author_name }}
            {% else %}
              <img src="{{ 'testimonial-portrait.jpg' | asset_url }}" alt="{{ block.settings.author_name }}" class="testimonials__portrait-img" loading="lazy">
            {% endif %}
          </div>

        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>

{% stylesheet %}
  .testimonials {
    grid-column: 1 / -1;
    width: 100%;
    box-sizing: border-box;
    padding: 80px 120px;
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 64px;
  }

  .testimonials__heading-wrap {
    text-align: center;
  }

  .testimonials__heading {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 700;
    color: #000;
    margin: 0;
    display: inline;
  }

  .testimonials__heading-hl {
    display: inline-block;
    position: relative;
  }

  .testimonials__heading-ellipse {
    position: absolute;
    left: 65%;
    transform: translateX(-50%);
    bottom: -10px;
    width: 80%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }

  .testimonials__slider {
    width: 100%;
    max-width: 996px;
    position: relative;
  }

  .testimonials__slide {
    display: none;
    align-items: center;
    gap: 97px;
  }

  .testimonials__slide--active {
    display: flex;
  }

  .testimonials__quote-wrap {
    display: flex;
    flex-direction: column;
    gap: 40px;
    flex: 1;
  }

  .testimonials__quote-mark {
    align-self: flex-start;
  }

  .testimonials__quote-icons {
    display: flex;
    gap: 4px;
    transform: scaleX(-1);
  }

  .testimonials__quote-icon {
    width: 48px;
    height: 48px;
    display: block;
  }

  .testimonials__content {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding-left: 81px;
  }

  .testimonials__text {
    font-family: var(--font-body);
    font-size: 24px;
    color: #000;
    margin: 0;
    line-height: 1.5;
    font-weight: 400;
  }

  .testimonials__author {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .testimonials__author-name {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: var(--gray, #828282);
    margin: 0;
  }

  .testimonials__author-location {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--gray, #828282);
    margin: 0;
    font-weight: 400;
  }

  .testimonials__controls {
    display: flex;
    align-items: center;
    gap: 24px;
    padding-left: 81px;
  }

  .testimonials__nav-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
  }

  .testimonials__nav-btn:hover { opacity: 0.7; }

  .testimonials__portrait {
    width: 245px;
    height: 321px;
    border-radius: 122.5px 122.5px 12px 12px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .testimonials__portrait-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 1100px) {
    .testimonials { padding: 60px 48px; gap: 48px; }
    .testimonials__slide { gap: 48px; }
    .testimonials__portrait { width: 200px; height: 262px; border-radius: 100px 100px 12px 12px; }
  }

  @media (max-width: 900px) {
    .testimonials { padding: 56px 32px; }
    .testimonials__slide { flex-direction: column-reverse; gap: 32px; align-items: flex-start; }
    .testimonials__portrait { width: 180px; height: 236px; border-radius: 90px 90px 12px 12px; }
    .testimonials__content { padding-left: 0; }
    .testimonials__controls { padding-left: 0; }
    .testimonials__heading { font-size: 40px; }
  }

  @media (max-width: 768px) {
    .testimonials { padding: 48px 24px; gap: 40px; }
    .testimonials__heading { font-size: 34px; }
    .testimonials__text { font-size: 18px; }
    .testimonials__portrait { width: 150px; height: 197px; border-radius: 75px 75px 12px 12px; align-self: center; }
  }

  @media (max-width: 480px) {
    .testimonials { padding: 40px 20px; gap: 32px; }
    .testimonials__heading { font-size: 28px; }
    .testimonials__text { font-size: 16px; }
    .testimonials__quote-icon { width: 36px; height: 36px; }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    document.querySelectorAll('[data-testimonials-next]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = btn.getAttribute('data-testimonials-next');
        var slider = document.getElementById('testimonials-' + id);
        if (!slider) return;
        var slides = slider.querySelectorAll('.testimonials__slide');
        var active = slider.querySelector('.testimonials__slide--active');
        var idx = Array.from(slides).indexOf(active);
        slides[idx].classList.remove('testimonials__slide--active');
        slides[(idx + 1) % slides.length].classList.add('testimonials__slide--active');
      });
    });
    document.querySelectorAll('[data-testimonials-prev]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = btn.getAttribute('data-testimonials-prev');
        var slider = document.getElementById('testimonials-' + id);
        if (!slider) return;
        var slides = slider.querySelectorAll('.testimonials__slide');
        var active = slider.querySelector('.testimonials__slide--active');
        var idx = Array.from(slides).indexOf(active);
        slides[idx].classList.remove('testimonials__slide--active');
        slides[(idx - 1 + slides.length) % slides.length].classList.add('testimonials__slide--active');
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Testimonials",
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Amazing service. My ring was a bit too big and they offered to resize it for free very swiftly."
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "Customer Name"
        },
        {
          "type": "text",
          "id": "author_location",
          "label": "Location",
          "default": "Sri Lanka"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author photo"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading_prefix",
      "label": "Heading – before highlight",
      "default": "What"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading – highlighted word(s) (gets ellipse)",
      "default": "People Say"
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "quote": "Amazing service. My ring was a bit too big and they offered to resize it for free and very swiftly.",
            "author_name": "Binguni Sanjana",
            "author_location": "Pannipitiya"
          }
        }
      ]
    }
  ]
}
{% endschema %}
