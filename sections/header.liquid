<header class="site-header">
  <div class="site-header__inner">
    <div class="site-header__logo">
      {% if section.settings.logo %}
        <a href="{{ routes.root_url }}" class="site-header__logo-link">
          {{ section.settings.logo | image_url: width: 400 | image_tag: alt: shop.name, class: 'site-header__logo-img', loading: 'eager', style: 'height:100px;width:auto;display:block;object-fit:contain;' }}
        </a>
      {% else %}
        <a href="{{ routes.root_url }}" class="site-header__logo-link">
          <img src="{{ 'at-logo.png' | asset_url }}" alt="{{ shop.name }}" loading="eager" style="height:150px;width:auto;display:block;object-fit:contain;max-width:240px;">
        </a>
      {% endif %}
    </div>

    <div class="site-header__actions">
      <a href="{{ routes.search_url }}" class="site-header__icon" aria-label="Search">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="11" cy="11" r="8" stroke="white" stroke-width="1.5"/>
          <path d="M21 21L16.65 16.65" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </a>

      <a href="{{ routes.cart_url }}" class="site-header__icon site-header__cart" aria-label="{{ 'cart.title' | t }}">
        {% if cart.item_count > 0 %}
          <span class="site-header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M6 2L3 6V20C3 21.1 3.9 22 5 22H19C20.1 22 21 21.1 21 20V6L18 2H6Z" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M3 6H21" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M16 10C16 12.2 14.2 14 12 14C9.8 14 8 12.2 8 10" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>

      <button class="site-header__hamburger" aria-label="Open menu" aria-expanded="false">
        <span></span>
        <span class="site-header__hamburger-short"></span>
      </button>
    </div>
  </div>
</header>

<script>
  (function () {
    var lastY   = 0;
    var ticking = false;

    function run() {
      var y      = window.pageYOffset || document.documentElement.scrollTop || 0;
      var header = document.querySelector('.site-header');
      var body   = document.body;

      /* Transparent at top; dark glass when scrolled */
      if (y > 60) {
        if (header) header.classList.add('site-header--scrolled');
      } else {
        if (header) header.classList.remove('site-header--scrolled');
        body.classList.remove('nav-hidden');
        lastY   = y;
        ticking = false;
        return;
      }

      /* Hide on scroll-down, show on scroll-up */
      if (y > lastY + 5) {
        body.classList.add('nav-hidden');
      } else if (y < lastY - 5) {
        body.classList.remove('nav-hidden');
      }

      lastY   = y;
      ticking = false;
    }

    window.addEventListener('scroll', function () {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(run);
      }
    }, { passive: true });

    /* Set correct initial state */
    run();
  })();
</script>

{% stylesheet %}
  .site-header {
    position: relative;
    grid-column: 1 / -1;
    width: 100%;
    height: 128px;
    background-color: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    transition: background-color 0.35s ease, transform 0.35s ease, backdrop-filter 0.35s ease;
    will-change: transform;
  }

  .site-header--scrolled {
    background-color: rgba(20, 10, 0, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 120px;
    max-width: 1440px;
    margin: 0 auto;
  }

  .site-header__logo-link {
    display: flex;
    align-items: center;
    height: 100%;
  }

  .site-header__logo-img {
    height: 100px;
    width: auto;
    display: block;
    object-fit: contain;
    max-width: 240px;
  }

  .site-header__logo-text {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: white;
    text-decoration: none;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .site-header__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    text-decoration: none;
    position: relative;
    flex-shrink: 0;
  }

  .site-header__cart { position: relative; }

  .site-header__cart-count {
    position: absolute;
    top: -8px;
    right: -8px;
    background-color: var(--coral-pink, #ff9696);
    color: white;
    font-size: 10px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-weight: 600;
  }

  .site-header__hamburger {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-end;
    justify-content: center;
    width: 27px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
  }

  .site-header__hamburger span {
    display: block;
    height: 4px;
    width: 100%;
    background-color: white;
    border-radius: 10px;
  }

  .site-header__hamburger-short { width: 18px !important; }

  @media (max-width: 1100px) {
    .site-header__inner { padding: 0 40px; }
  }

  @media (max-width: 768px) {
    .site-header { height: 80px; }
    .site-header__inner { padding: 0 20px; }
    .site-header__logo-img { height: 65px !important; max-width: 180px; }
    .site-header__actions { gap: 14px; }
  }

  @media (max-width: 480px) {
    .site-header { height: 70px; }
    .site-header__logo-img { height: 55px !important; max-width: 150px; }
    .site-header__inner { padding: 0 16px; }
    .site-header__icon { width: 22px; height: 22px; }
  }

  @media (max-width: 375px) {
    .site-header__logo-img { height: 48px !important; max-width: 130px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
