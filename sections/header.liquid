<header class="site-header">
  <div class="site-header__inner">
    <div class="site-header__logo">
      {% if section.settings.logo %}
        <a href="{{ routes.root_url }}" class="site-header__logo-link">
          {{ section.settings.logo | image_url: width: 400 | image_tag: alt: shop.name, class: 'site-header__logo-img', loading: 'eager', style: 'height:100px;width:auto;display:block;object-fit:contain;' }}
        </a>
      {% else %}
        <a href="{{ routes.root_url }}" class="site-header__logo-link">
          <img src="{{ 'at-logo.png' | asset_url }}" alt="{{ shop.name }}" loading="eager" style="height:150px;width:auto;display:block;object-fit:contain;max-width:240px;">
        </a>
      {% endif %}
    </div>

    <div class="site-header__actions">
      <button class="site-header__icon js-at-modal" data-modal="search" aria-label="Search" aria-expanded="false">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <circle cx="11" cy="11" r="8" stroke="white" stroke-width="1.5"/>
          <path d="M21 21L16.65 16.65" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>

      <button class="site-header__icon site-header__cart js-at-modal" data-modal="cart" aria-label="{{ 'cart.title' | t }}" aria-expanded="false">
        {% if cart.item_count > 0 %}
          <span class="site-header__cart-count js-cart-badge">{{ cart.item_count }}</span>
        {% else %}
          <span class="site-header__cart-count js-cart-badge" style="display:none;">0</span>
        {% endif %}
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M6 2L3 6V20C3 21.1 3.9 22 5 22H19C20.1 22 21 21.1 21 20V6L18 2H6Z" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M3 6H21" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M16 10C16 12.2 14.2 14 12 14C9.8 14 8 12.2 8 10" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <button class="site-header__hamburger js-at-modal" data-modal="nav" aria-label="Open menu" aria-expanded="false">
        <span></span>
        <span class="site-header__hamburger-short"></span>
      </button>
    </div>
  </div>
</header>

{%- comment -%} ── NAV MODAL ── {%- endcomment -%}
<div id="at-modal-nav" class="at-modal" role="dialog" aria-modal="true" aria-label="Navigation menu" aria-hidden="true">
  <div class="at-modal__bar">
    <div class="at-modal__bar-logo">
      {% if section.settings.logo %}
        <a href="{{ routes.root_url }}">{{ section.settings.logo | image_url: width: 400 | image_tag: alt: shop.name, class: 'at-modal__logo-img', loading: 'lazy' }}</a>
      {% else %}
        <a href="{{ routes.root_url }}"><img src="{{ 'at-logo.png' | asset_url }}" alt="{{ shop.name }}" class="at-modal__logo-img"></a>
      {% endif %}
    </div>
    <div class="at-modal__bar-actions">
      <button class="at-modal__icon js-at-modal" data-modal="search" aria-label="Search">
        <img src="{{ 'icon-search.svg' | asset_url }}" width="24" height="24" alt="">
      </button>
      <button class="at-modal__icon at-modal__cart-btn js-at-modal" data-modal="cart" aria-label="Cart">
        {% if cart.item_count > 0 %}<span class="site-header__cart-count js-cart-badge">{{ cart.item_count }}</span>{% else %}<span class="site-header__cart-count js-cart-badge" style="display:none;">0</span>{% endif %}
        <img src="{{ 'icon-bag.svg' | asset_url }}" width="24" height="24" alt="">
      </button>
      <button class="at-modal__icon at-modal__close-btn js-at-close" aria-label="Close menu">
        <img src="{{ 'icon-close.svg' | asset_url }}" width="24" height="24" alt="">
      </button>
    </div>
  </div>

  <nav class="at-modal__nav">
    <ul class="at-modal__nav-list">
      {% if linklists[section.settings.menu].links.size > 0 %}
        {% for link in linklists[section.settings.menu].links %}
          <li><a href="{{ link.url }}" class="at-modal__nav-link">{{ link.title }}</a></li>
        {% endfor %}
      {% else %}
        <li><a href="{{ routes.root_url }}" class="at-modal__nav-link">Home</a></li>
        <li><a href="/collections/bridal-jewellery" class="at-modal__nav-link">Bridal Jewellery</a></li>
        <li><a href="/collections/costume-jewellery" class="at-modal__nav-link">Costume Jewellery</a></li>
        <li><a href="/pages/contact" class="at-modal__nav-link">Contact Us</a></li>
        <li><a href="/pages/about" class="at-modal__nav-link">About Us</a></li>
      {% endif %}
    </ul>
  </nav>

  <div class="at-modal__social">
    <a href="{{ section.settings.social_facebook | default: '#' }}" class="at-modal__social-icon" aria-label="Facebook" {% if section.settings.social_facebook != blank %}target="_blank" rel="noopener"{% endif %}>
      <img src="{{ 'icon-facebook.svg' | asset_url }}" width="48" height="48" alt="Facebook">
    </a>
    <a href="{{ section.settings.social_instagram | default: '#' }}" class="at-modal__social-icon" aria-label="Instagram" {% if section.settings.social_instagram != blank %}target="_blank" rel="noopener"{% endif %}>
      <img src="{{ 'icon-instagram.svg' | asset_url }}" width="48" height="48" alt="Instagram">
    </a>
    <a href="{{ section.settings.social_tiktok | default: '#' }}" class="at-modal__social-icon" aria-label="TikTok" {% if section.settings.social_tiktok != blank %}target="_blank" rel="noopener"{% endif %}>
      <img src="{{ 'icon-tiktok.svg' | asset_url }}" width="48" height="48" alt="TikTok">
    </a>
    <a href="{{ section.settings.social_youtube | default: '#' }}" class="at-modal__social-icon" aria-label="YouTube" {% if section.settings.social_youtube != blank %}target="_blank" rel="noopener"{% endif %}>
      <img src="{{ 'icon-youtube.svg' | asset_url }}" width="48" height="48" alt="YouTube">
    </a>
  </div>
</div>

