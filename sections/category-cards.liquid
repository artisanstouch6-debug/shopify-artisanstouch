<div class="cat-section full-width">
  <div class="cat-section__heading-wrap">
    <h2 class="cat-section__heading">
      <span class="cat-section__heading-line1">
        Discover
        <span class="cat-section__heading-jewellery">
          Jewellery
          <img src="{{ 'heading-swirl.svg' | asset_url }}" alt="" class="cat-section__heading-swirl" aria-hidden="true">
        </span>
      </span>
      <span class="cat-section__heading-line2">{{ section.settings.heading_line2 | default: 'Collection' }}</span>
    </h2>
  </div>

  <div class="cat-section__cards">
    {%- comment -%} Card 1 – Bridal (image overlaps right side) {%- endcomment -%}
    <div class="cat-card cat-card--left" style="--card-bg: {{ section.settings.card_1_bg | default: '#ffe4e4' }};">
      <div class="cat-card__bg" style="background-color: {{ section.settings.card_1_bg | default: '#ffe4e4' }};"></div>
      <div class="cat-card__text">
        <h3 class="cat-card__title">{{ section.settings.card_1_title }}</h3>
        <p class="cat-card__desc">{{ section.settings.card_1_description }}</p>
      </div>
      <a href="{{ section.settings.card_1_url }}" class="at-btn">
        {{ section.settings.card_1_button }}
        <img src="{{ 'icon-arrow.svg' | asset_url }}" width="18" height="18" alt="" class="at-btn__arrow">
      </a>
      <div class="cat-card__image cat-card__image--right">
        {% if section.settings.card_1_image %}
          {{ section.settings.card_1_image | image_url: width: 320, height: 420, crop: 'center' | image_tag: class: 'cat-card__img', loading: 'lazy', alt: section.settings.card_1_title }}
        {% else %}
          <img src="{{ 'bridal-jewellery.jpg' | asset_url }}" alt="{{ section.settings.card_1_title }}" class="cat-card__img">
        {% endif %}
      </div>
    </div>

    {%- comment -%} Card 2 – Costume (image overlaps left side) {%- endcomment -%}
    <div class="cat-card cat-card--right" style="--card-bg: {{ section.settings.card_2_bg | default: '#f5e8c0' }};">
      <div class="cat-card__bg" style="background-color: {{ section.settings.card_2_bg | default: '#f5e8c0' }};"></div>
      <div class="cat-card__image cat-card__image--left">
        {% if section.settings.card_2_image %}
          {{ section.settings.card_2_image | image_url: width: 260, height: 360, crop: 'center' | image_tag: class: 'cat-card__img cat-card__img--pill', loading: 'lazy', alt: section.settings.card_2_title }}
        {% else %}
          <img src="{{ 'costume-jewellery.jpg' | asset_url }}" alt="{{ section.settings.card_2_title }}" class="cat-card__img cat-card__img--pill">
        {% endif %}
      </div>
      <div class="cat-card__text cat-card__text--right">
        <h3 class="cat-card__title">{{ section.settings.card_2_title }}</h3>
        <p class="cat-card__desc">{{ section.settings.card_2_description }}</p>
      </div>
      <a href="{{ section.settings.card_2_url }}" class="at-btn">
        {{ section.settings.card_2_button }}
        <img src="{{ 'icon-arrow.svg' | asset_url }}" width="18" height="18" alt="" class="at-btn__arrow">
      </a>
    </div>
  </div>
</div>

{% stylesheet %}
  .cat-section {
    grid-column: 1 / -1;
    width: 100%;
    padding: 64px 80px;
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
    box-sizing: border-box;
  }

  .cat-section__heading-wrap {
    text-align: center;
  }

  .cat-section__heading {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 600;
    color: #000;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    line-height: 1.15;
  }

  .cat-section__heading-line1 {
    display: block;
  }

  .cat-section__heading-line2 {
    display: block;
  }

  .cat-section__heading-jewellery {
    display: inline-block;
    position: relative;
    z-index: 0;
  }

  .cat-section__heading-swirl {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: -20px;
    width: 140%;
    height: auto;
    z-index: -1;
    pointer-events: none;
  }

  .cat-section__cards {
    display: flex;
    gap: 69px;
    align-items: center;
  }

  .cat-card {
    position: relative;
    flex: 1;
    height: 556px;
    display: flex;
    align-items: flex-start;
  }

  .cat-card__bg {
    position: absolute;
    border-radius: 12px;
    top: 42px;
    left: 0;
    width: 68.5%;
    height: 475px;
    box-shadow: 0 4px 40px #00000015;
  }

  .cat-card--right .cat-card__bg {
    left: auto;
    right: 0;
    width: 66.9%;
    top: 0;
    height: 510px;
  }

  .cat-card__text {
    position: absolute;
    top: 0;
    left: 6.7%;
    display: flex;
    flex-direction: column;
    gap: 31px;
    z-index: 2;
    width: 55.6%;
  }

  .cat-card__text--right {
    left: auto;
    right: 0;
    top: 36px;
    width: 52%;
    padding-right: 20px;
    padding-left:10px;
  }

  .cat-card__title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 700;
    color: #000;
    margin: 0;
    line-height: 1.1;
  }

  .cat-card__desc {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--gray, #828282);
    margin: 0;
    line-height: 1.6;
  }

  /* Card 1 only: cap desc width so it doesn't run behind the right-side product image */
  .cat-card--left .cat-card__desc { width: 56%; }

  .at-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 1px solid var(--coral-pink, #ff9696);
    color: var(--coral-pink, #ff9696);
    padding: 10px 20px;
    border-radius: 24px;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.05em;
    transition: background-color 0.2s, color 0.2s;
    cursor: pointer;
    white-space: nowrap;
    align-self: flex-start;
    margin-top: auto;
  }

  .at-btn:hover {
    background-color: var(--coral-pink, #ff9696);
    color: white;
  }

  .at-btn__arrow {
    display: block;
    flex-shrink: 0;
    transform: rotate(90deg);
  }

  .cat-card--left .at-btn {
    position: absolute;
    bottom: 80px;
    left: 6.7%;
  }

  .cat-card--right .at-btn {
    position: absolute;
    bottom: 76px;
    right: 24px;
  }

  .cat-card__image--right {
    position: absolute;
    right: -10px;
    top: 137px;
    width: 56.1%;
    height: 419px;
    z-index: 2;
  }

  .cat-card__image--left {
    position: absolute;
    left: 0;
    top: 28px;
    width: 45.3%;
    height: 360px;
    z-index: 2;
  }

  .cat-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
    display: block;
  }

  .cat-card__img--pill {
    border-radius: 128px 128px 12px 12px;
  }

  .cat-card__img-placeholder {
    width: 100%;
    height: 100%;
    background: #ddd;
    border-radius: 12px;
  }

  .cat-card__img-placeholder--pill {
    border-radius: 128px 128px 12px 12px;
  }

  /* ══ TABLET 769px–1299px: flex row per stacked card ══ */
  @media (min-width: 769px) and (max-width: 1299px) {
    .cat-section { padding: 52px 28px; }
    .cat-section__heading { font-size: 32px; }
    .cat-section__cards { flex-direction: column; gap: 28px; }

    /* ── reset the card from absolute layout to clean flex ── */
    .cat-card,
    .cat-card--left,
    .cat-card--right {
      position: relative;
      flex: none;
      width: 100%;
      height: 480px;
      display: flex;
      flex-direction: row;
      align-items: stretch;
      overflow: hidden;
      border-radius: 24px;
      box-shadow: 0 6px 40px rgba(0,0,0,0.07);
    }

    .cat-card__bg { display: none; }
    .cat-card--left { background-color: var(--card-bg, #ffe4e4); }
    .cat-card--right { background-color: var(--card-bg, #f5e8c0); }

    /* ── Card 1: text+btn column on left, image on right ── */
    .cat-card--left .cat-card__text {
      position: static;
      flex: 0 0 42%;
      width: 42%;
      min-width: 0;
      overflow: hidden;
      height: auto;
      padding: 40px 32px 88px 40px;
      gap: 16px;
      z-index: 1;
      top: auto; left: auto;
    }

    .cat-card--left .cat-card__image--right {
      position: static;
      flex: 1;
      min-width: 0;
      width: auto;
      height: 100%;
      top: auto; right: auto;
    }

    .cat-card--left .cat-card__image--right .cat-card__img {
      width: 100%; height: 100%;
      object-fit: cover; border-radius: 0;
    }

    .cat-card--left .at-btn {
      position: absolute;
      bottom: 32px; left: 40px;
      right: auto; top: auto; margin: 0;
    }

    .cat-card--left .cat-card__desc { width: 100%; }

    /* ── Card 2: image on left, text+btn column on right ── */
    .cat-card--right .cat-card__image--left {
      position: static;
      flex: 0 0 48%;
      width: 48%;
      min-width: 0;
      height: 100%;
      top: auto; left: auto;
    }

    .cat-card--right .cat-card__image--left .cat-card__img,
    .cat-card--right .cat-card__image--left .cat-card__img--pill {
      width: 100%; height: 100%;
      object-fit: cover; border-radius: 16px;
    }

    .cat-card--right .cat-card__text--right {
      position: static;
      flex: 1;
      min-width: 0;
      overflow: hidden;
      width: auto;
      height: auto;
      padding: 40px 36px 88px 32px;
      gap: 16px;
      top: auto; right: auto;
    }

    .cat-card--right .at-btn {
      position: absolute;
      bottom: 32px; right: 40px;
      left: auto; top: auto; margin: 0;
    }

    .cat-card__title { font-size: 38px; }
    .cat-card__desc { font-size: 15px; width: auto; word-break: break-word; overflow-wrap: break-word; }
    .cat-card--left .cat-card__desc { width: auto; }
  }

  /* ══ MOBILE ≤768px: overlapping design, stacked top + bottom ══ */
  @media (max-width: 768px) {
    .cat-section { padding: 40px 0; }
    .cat-section__heading { font-size: 26px; padding: 0 20px; }
    .cat-section__cards { flex-direction: column; gap: 48px; padding: 0 20px; }

    .cat-card,
    .cat-card--left,
    .cat-card--right {
      position: relative;
      flex: none;
      width: 100%;
      height: auto;
      display: block;
      overflow: visible;
      background: none;
      border-radius: 0;
      box-shadow: none;
      padding: 0;
    }

    /* ── Card 1: bg on left, image overlaps from right ── */
    /* Image starts at right:0; width:52% → left edge of image = 48% from left.
       Text width 43% → text content ends at ~43%. Gap = 5%. No overlap. */
    .cat-card--left .cat-card__bg {
      display: block !important;
      position: absolute;
      top: 48px; left: 0; bottom: 0;
      width: 70%; height: auto;
      border-radius: 20px;
      box-shadow: 0 4px 28px #00000014;
      z-index: 1;
    }

    .cat-card--left .cat-card__text {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 30px;
      z-index: 2;
      width: 43%;
      padding: 64px 10px 80px 18px;
      top: auto; left: auto; right: auto;
    }

    .cat-card--left .cat-card__desc { width: 100%; word-break: break-word; }

    .cat-card--left .cat-card__image--right {
      position: absolute;
      right: 0; top: 0; left: auto;
      width: 52%; height: 280px;
      z-index: 4;
    }

    .cat-card--left .cat-card__image--right .cat-card__img {
      border-radius: 16px;
    }

    .cat-card--left .at-btn {
      position: absolute;
      bottom: 22px; left: 18px;
      right: auto; top: auto; margin: 0;
      z-index: 3;
    }

    /* ── Card 2: bg on right, arch image overlaps from left ── */
    /* Image width:41% → right edge = 41%. Text margin-left:43% → starts at 43%. Gap = 2%. */
    .cat-card--right .cat-card__bg {
      display: block !important;
      position: absolute;
      top: 0; right: 0; bottom: 0; left: auto;
      width: 68%; height: auto;
      border-radius: 20px;
      box-shadow: 0 4px 28px #00000014;
      z-index: 1;
    }

    .cat-card--right .cat-card__image--left {
      position: absolute;
      left: 0; top: 0; right: auto;
      width: 41%; height: 260px;
      z-index: 4;
    }

    .cat-card--right .cat-card__image--left .cat-card__img--pill {
      border-radius: 16px;
    }

    .cat-card--right .cat-card__text--right {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 30px;
      z-index: 2;
      margin-left: 43%;
      width: auto;
      padding: 18px 14px 80px 10px;
      top: auto; right: auto; left: auto;
    }

    .cat-card--right .cat-card__desc { word-break: break-word; }

    .cat-card--right .at-btn {
      position: absolute;
      bottom: 22px; right: 18px;
      left: auto; top: auto; margin: 0;
      z-index: 3;
    }

    /* min-height ensures card is never shorter than the absolute image */
    .cat-card--left { min-height: 330px; }
    .cat-card--right { min-height: 310px; }

    .cat-card__img {
      width: 100%; height: 100%;
      object-fit: cover; border-radius: 16px;
    }

    .cat-card__img--pill { border-radius: 16px; }
    .cat-card__title { font-size: 30px; line-height: 1.1; }
    .cat-card__desc { font-size: 14px; }
  }

  /* ══ SMALL MOBILE ≤480px ══ */
  @media (max-width: 480px) {
    .cat-section { padding: 32px 0; }
    .cat-section__heading { font-size: 22px; padding: 0 16px; }
    .cat-section__cards { padding: 0 16px; }
    .cat-section__heading-swirl { width: 120%; }

    .cat-card--left { min-height: 300px; }
    .cat-card--right { min-height: 280px; }

    /* Image C1: 50% wide → starts at 50%. Text: 40% → ends at ~40%. Gap 10%. */
    .cat-card--left .cat-card__bg { width: 68%; top: 42px; }
    .cat-card--left .cat-card__text { width: 40%; padding: 58px 8px 72px 14px; }
    .cat-card--left .cat-card__image--right { width: 50%; height: 240px; }
    .cat-card--left .at-btn { bottom: 18px; left: 14px; }

    /* Image C2: 39% wide → ends at 39%. Text: margin-left 41% → gap 2%. */
    .cat-card--right .cat-card__bg { width: 66%; }
    .cat-card--right .cat-card__image--left { width: 39%; height: 300px; }
    .cat-card--right .cat-card__text--right { margin-left: 41%; padding: 14px 12px 72px 8px; }
    .cat-card--right .at-btn { bottom: 18px; right: 14px; left: auto; }

    .cat-card__title { font-size: 26px; }
    .cat-card__desc { font-size: 13px; }
    .at-btn { font-size: 13px; padding: 8px 14px; }
  }
{% endstylesheet %}

{% schema %}
