<div class="cat-section full-width">
  <div class="cat-section__heading-wrap">
    <h2 class="cat-section__heading">{{ section.settings.heading }}</h2>
  </div>

  <div class="cat-section__cards">
    {%- comment -%} Card 1 – Bridal (image overlaps right side) {%- endcomment -%}
    <div class="cat-card cat-card--left" style="--card-bg: {{ section.settings.card_1_bg }};">
      <div class="cat-card__bg"></div>
      <div class="cat-card__text">
        <h3 class="cat-card__title">{{ section.settings.card_1_title }}</h3>
        <p class="cat-card__desc">{{ section.settings.card_1_description }}</p>
        <a href="{{ section.settings.card_1_url }}" class="at-btn">
          {{ section.settings.card_1_button }}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M5 12H19M12 5L19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
      <div class="cat-card__image cat-card__image--right">
        {% if section.settings.card_1_image %}
          {{ section.settings.card_1_image | image_url: width: 320, height: 420, crop: 'center' | image_tag: class: 'cat-card__img', loading: 'lazy', alt: section.settings.card_1_title }}
        {% else %}
          <img src="{{ 'bridal-jewellery.jpg' | asset_url }}" alt="{{ section.settings.card_1_title }}" class="cat-card__img">
        {% endif %}
      </div>
    </div>

    {%- comment -%} Card 2 – Costume (image overlaps left side) {%- endcomment -%}
    <div class="cat-card cat-card--right" style="--card-bg: {{ section.settings.card_2_bg }};">
      <div class="cat-card__image cat-card__image--left">
        {% if section.settings.card_2_image %}
          {{ section.settings.card_2_image | image_url: width: 260, height: 360, crop: 'center' | image_tag: class: 'cat-card__img cat-card__img--pill', loading: 'lazy', alt: section.settings.card_2_title }}
        {% else %}
          <img src="{{ 'costume-jewellery.jpg' | asset_url }}" alt="{{ section.settings.card_2_title }}" class="cat-card__img cat-card__img--pill">
        {% endif %}
      </div>
      <div class="cat-card__text cat-card__text--right">
        <h3 class="cat-card__title">{{ section.settings.card_2_title }}</h3>
        <p class="cat-card__desc">{{ section.settings.card_2_description }}</p>
        <a href="{{ section.settings.card_2_url }}" class="at-btn">
          {{ section.settings.card_2_button }}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M5 12H19M12 5L19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .cat-section {
    padding: 64px 120px;
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .cat-section__heading-wrap {
    text-align: center;
  }

  .cat-section__heading {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 600;
    color: #000;
    margin: 0;
    display: inline-block;
    position: relative;
  }

  .cat-section__cards {
    display: flex;
    gap: 69px;
    align-items: center;
  }

  .cat-card {
    position: relative;
    flex: 1;
    height: 556px;
    display: flex;
    align-items: flex-start;
  }

  .cat-card__bg {
    position: absolute;
    background-color: var(--card-bg, #ffe4e4);
    border-radius: 12px;
    top: 42px;
    left: 0;
    width: 68.5%;
    height: 475px;
  }

  .cat-card--right .cat-card__bg {
    left: auto;
    right: 0;
    width: 66.9%;
    top: 0;
  }

  .cat-card__text {
    position: absolute;
    top: 0;
    left: 6.7%;
    display: flex;
    flex-direction: column;
    gap: 31px;
    z-index: 2;
    width: 55.6%;
  }

  .cat-card__text--right {
    left: auto;
    right: 0;
    top: 59px;
    width: 40.2%;
  }

  .cat-card__title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 700;
    color: #000;
    margin: 0;
    line-height: 1.1;
  }

  .cat-card__desc {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--gray, #828282);
    margin: 0;
    line-height: 1.6;
    width: 48%;
  }

  .at-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 1px solid var(--coral-pink, #ff9696);
    color: var(--coral-pink, #ff9696);
    padding: 10px 20px;
    border-radius: 24px;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.05em;
    transition: background-color 0.2s, color 0.2s;
    cursor: pointer;
    white-space: nowrap;
    align-self: flex-start;
    margin-top: auto;
  }

  .at-btn:hover {
    background-color: var(--coral-pink, #ff9696);
    color: white;
  }

  .cat-card--left .at-btn {
    position: absolute;
    bottom: 120px;
    left: 6.7%;
  }

  .cat-card--right .at-btn {
    position: absolute;
    bottom: 120px;
    left: 6.7%;
  }

  .cat-card__image--right {
    position: absolute;
    right: 0;
    top: 137px;
    width: 56.1%;
    height: 419px;
    z-index: 2;
  }

  .cat-card__image--left {
    position: absolute;
    left: 0;
    top: 28px;
    width: 45.3%;
    height: 360px;
    z-index: 2;
  }

  .cat-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
    display: block;
  }

  .cat-card__img--pill {
    border-radius: 128px 128px 12px 12px;
  }

  .cat-card__img-placeholder {
    width: 100%;
    height: 100%;
    background: #ddd;
    border-radius: 12px;
  }

  .cat-card__img-placeholder--pill {
    border-radius: 128px 128px 12px 12px;
  }

  @media (max-width: 1100px) {
    .cat-section { padding: 48px 40px; }
    .cat-section__cards { gap: 32px; flex-direction: column; }
    .cat-card { width: 100%; }
  }

  /* ── Mobile: convert absolute layout to normal flow ── */
  @media (max-width: 768px) {
    .cat-section { padding: 40px 20px; }
    .cat-section__cards { flex-direction: column; gap: 28px; }

    .cat-card {
      width: 100%;
      height: auto;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      overflow: hidden;
      border-radius: 16px;
      background-color: var(--card-bg, #ffe4e4);
      padding: 24px 20px 20px;
    }

    .cat-card__bg { display: none; }

    .cat-card__text,
    .cat-card__text--right {
      position: static;
      width: 100%;
      gap: 12px;
      order: 1;
    }

    .cat-card__image--right,
    .cat-card__image--left {
      position: static;
      width: 100%;
      height: 220px;
      border-radius: 12px;
      overflow: hidden;
      margin-top: 20px;
      order: 2;
    }

    .cat-card--left .at-btn,
    .cat-card--right .at-btn {
      position: static;
      margin-top: 16px;
    }

    .cat-card__title { font-size: 28px; }
    .cat-card__desc { width: auto; }
  }
{% endstylesheet %}

