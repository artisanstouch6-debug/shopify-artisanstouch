    },
    {
      "type": "text",
      "id": "card_2_button",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "card_2_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Category Cards"
    }
  ]
