<div class="pgrid full-width" style="background-color: var(--accent, #f5e6da);">
  <div class="pgrid__inner">
    <div class="pgrid__header">
      <div class="pgrid__title-wrap">
        <h2 class="pgrid__title">
          {{ section.settings.heading_prefix }}
          <span class="pgrid__title-highlight">
            {{ section.settings.heading_highlight }}
            <img src="{{ 'heading-swirl.svg' | asset_url }}" alt="" class="pgrid__title-swirl" aria-hidden="true">
          </span>
        </h2>
      </div>
      <div class="pgrid__subtitle-row">
        <p class="pgrid__subtitle">{{ section.settings.subheading }}</p>
        <div class="pgrid__nav">
          <button class="pgrid__nav-btn pgrid__nav-btn--prev" aria-label="Previous" data-carousel-prev="{{ section.id }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" viewBox="0 0 50 50" fill="none">
              <path d="M16.6667 39.5834C16.6667 38.0375 15.1396 35.7292 13.5937 33.7917C11.6062 31.2917 9.23125 29.1105 6.50833 27.4459C4.46667 26.198 1.99167 25 0 25M0 25C1.99167 25 4.46875 23.8021 6.50833 22.5542C9.23125 20.8875 11.6062 18.7063 13.5937 16.2105C15.1396 14.2709 16.6667 11.9584 16.6667 10.4167M0 25H50" stroke="#FF9696" stroke-opacity="0.5" stroke-width="4"/>
            </svg>
          </button>
          <button class="pgrid__nav-btn pgrid__nav-btn--next" aria-label="Next" data-carousel-next="{{ section.id }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="75" height="50" viewBox="0 0 75 50" fill="none">
              <g clip-path="url(#clip0_83_120)">
                <path d="M50 10.4166C50 11.9625 52.2906 14.2708 54.6094 16.2083C57.5906 18.7083 61.1531 20.8895 65.2375 22.5541C68.3 23.802 72.0125 25 75 25M75 25C72.0125 25 68.2969 26.1979 65.2375 27.4458C61.1531 29.1125 57.5906 31.2937 54.6094 33.7895C52.2906 35.7291 50 38.0416 50 39.5833M75 25H0" stroke="#FF9696" stroke-width="4"/>
              </g>
              <defs>
                <clipPath id="clip0_83_120">
                  <rect width="50" height="75" fill="white" transform="matrix(0 1 -1 0 75 0)"/>
                </clipPath>
              </defs>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="pgrid__track" id="pgrid-track-{{ section.id }}">
      {%- assign featured_collection = collections[section.settings.collection] -%}
      {%- if featured_collection != blank -%}
        {%- for product in featured_collection.products limit: section.settings.products_count -%}
          <div class="pcard">
            <a href="{{ product.url }}" class="pcard__image-link">
              {%- if product.featured_image -%}
                {{ product.featured_image | image_url: width: 285, height: 285, crop: 'center' | image_tag: class: 'pcard__img', loading: 'lazy', alt: product.featured_image.alt | default: product.title }}
              {%- else -%}
                <div class="pcard__img pcard__img--placeholder">{{ 'image' | placeholder_svg_tag }}</div>
              {%- endif -%}
            </a>
            <div class="pcard__info">
              <div class="pcard__row">
                <a href="{{ product.url }}" class="pcard__title">{{ product.title }}</a>
                <div class="pcard__actions">
                  <button class="pcard__action-btn pcard__wish" aria-label="Add to wishlist"
                          data-id="{{ product.id }}"
                          data-title="{{ product.title | escape }}"
                          data-price="{{ product.price | money }}"
                          data-image="{{ product.featured_image | image_url: width: 300 }}"
                          data-url="{{ product.url }}">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12.62 20.8101C12.28 20.9301 11.72 20.9301 11.38 20.8101C8.48 19.8201 2 15.6901 2 8.6901C2 5.6001 4.49 3.1001 7.56 3.1001C9.38 3.1001 10.99 3.9801 12 5.3401C13.01 3.9801 14.63 3.1001 16.44 3.1001C19.51 3.1001 22 5.6001 22 8.6901C22 15.6901 15.52 19.8201 12.62 20.8101Z" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <button class="pcard__action-btn pcard__atc" aria-label="Add to cart" data-variant-id="{{ product.first_available_variant.id }}">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M7.5 7.67001V6.70001C7.5 4.45001 9.31 2.24001 11.56 2.03001C14.24 1.77001 16.5 3.88001 16.5 6.51001V7.89001" stroke="black" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M8.99999 22H15C19.02 22 19.74 20.39 19.95 18.43L20.7 12.43C20.97 9.99 20.27 8 16 8H7.99999C3.72999 8 3.02999 9.99 3.29999 12.43L4.04999 18.43C4.25999 20.39 4.97999 22 8.99999 22Z" stroke="black" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M15.4955 12H15.5045" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M8.49451 12H8.50349" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
              </div>
              <p class="pcard__price">{{ product.price | money }}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- assign demo_images = 'product-rose-gold-ring.jpg,product-gold-necklace.jpg,product-rose-gold-bracelet.jpg,product-diamond-earrings.jpg' | split: ',' -%}
        {%- assign demo_titles = 'Rose Gold Casual Ring,Gold Wedding Necklace,Rose Gold Bracelet,Diamond Earrings' | split: ',' -%}
        {%- assign demo_prices = 'LKR 14,000.00,LKR 25,000.00,LKR 10,500.00,LKR 7,800.00' | split: ',' -%}
        {%- for i in (0..3) -%}
          <div class="pcard">
            <div class="pcard__image-link">
              <img src="{{ demo_images[i] | asset_url }}" alt="{{ demo_titles[i] }}" class="pcard__img" loading="lazy">
            </div>
            <div class="pcard__info">
              <div class="pcard__row">
                <span class="pcard__title">{{ demo_titles[i] }}</span>
                <div class="pcard__actions">
                  <button class="pcard__action-btn" aria-label="Wishlist">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12.62 20.8101C12.28 20.9301 11.72 20.9301 11.38 20.8101C8.48 19.8201 2 15.6901 2 8.6901C2 5.6001 4.49 3.1001 7.56 3.1001C9.38 3.1001 10.99 3.9801 12 5.3401C13.01 3.9801 14.63 3.1001 16.44 3.1001C19.51 3.1001 22 5.6001 22 8.6901C22 15.6901 15.52 19.8201 12.62 20.8101Z" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <button class="pcard__action-btn" aria-label="Add to cart">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M7.5 7.67001V6.70001C7.5 4.45001 9.31 2.24001 11.56 2.03001C14.24 1.77001 16.5 3.88001 16.5 6.51001V7.89001" stroke="black" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M8.99999 22H15C19.02 22 19.74 20.39 19.95 18.43L20.7 12.43C20.97 9.99 20.27 8 16 8H7.99999C3.72999 8 3.02999 9.99 3.29999 12.43L4.04999 18.43C4.25999 20.39 4.97999 22 8.99999 22Z" stroke="black" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M15.4955 12H15.5045" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M8.49451 12H8.50349" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
              </div>
              <p class="pcard__price">{{ demo_prices[i] }}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .pgrid {
    width: 100%;
  }

  .pgrid__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 52px 120px;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .pgrid__header {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pgrid__title-wrap {
    position: relative;
    display: inline-block;
  }

  .pgrid__title {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 600;
    color: #000;
    margin: 0;
  }

  .pgrid__title-highlight {
    display: inline-block;
    position: relative;
    z-index: 0;
  }

  .pgrid__title-swirl {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: -35px;
    width: 310px;
    height: 110px;
    z-index: -1;
    pointer-events: none;
  }

  .pgrid__subtitle-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .pgrid__subtitle {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--gray, #828282);
    margin: 0;
    max-width: 530px;
  }

  .pgrid__nav {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-shrink: 0;
  }

  .pgrid__nav-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
  }

  .pgrid__nav-btn:hover { opacity: 0.7; }

  .pgrid__track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .pgrid__track::-webkit-scrollbar { display: none; }

  .pcard {
    flex: 0 0 285px;
    display: flex;
    flex-direction: column;
    gap: 17px;
    scroll-snap-align: start;
  }

  .pcard__image-link {
    display: block;
    width: 285px;
    height: 285px;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    flex-shrink: 0;
  }

  .pcard__img {
    width: 285px;
    height: 285px;
    object-fit: cover;
    border-radius: 12px;
    display: block;
    transition: transform 0.3s;
  }

  .pcard__image-link:hover .pcard__img { transform: scale(1.03); }

  .pcard__img--placeholder {
    background: #f0e8e8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pcard__img--placeholder svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .pcard__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pcard__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .pcard__title {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    color: #000;
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
  }

  .pcard__actions {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }

  .pcard__action-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
    text-decoration: none;
  }

  .pcard__action-btn:hover { opacity: 0.6; }
  .pcard__wish--on path { fill: #ff4d4d; stroke: #ff4d4d; }
  .pcard__wish--on { opacity: 1 !important; }

  .pcard__price {
    font-family: var(--font-body);
    font-size: 16px;
    color: #000;
    margin: 0;
    font-weight: 400;
  }

  @media (max-width: 1100px) {
    .pgrid__inner { padding: 40px 48px; }
  }

  @media (max-width: 768px) {
    .pgrid__inner { padding: 40px 24px; }
    .pcard { flex: 0 0 240px; }
    .pcard__image-link, .pcard__img { width: 240px; height: 240px; }
    .pgrid__nav { gap: 12px; }
    .pgrid__nav-btn svg { width: 28px; height: 28px; }
  }

  /* ── Toast notifications ── */
  #at-toast-container {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 10px;
    pointer-events: none;
  }

  .at-toast {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #1a1a1a;
    color: white;
    padding: 14px 18px;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.28);
    font-family: var(--font-body);
    min-width: 240px;
    max-width: 300px;
    border-left: 4px solid #22c55e;
    transform: translateX(calc(100% + 28px));
    opacity: 0;
    transition: transform 0.38s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.25s ease;
  }

  .at-toast--in {
    transform: translateX(0);
    opacity: 1;
  }

  .at-toast--out {
    transform: translateX(calc(100% + 28px));
    opacity: 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .at-toast__icon {
    width: 30px;
    height: 30px;
    background: #22c55e;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .at-toast__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    overflow: hidden;
  }

  .at-toast__title {
    font-size: 13px;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .at-toast__msg {
    font-size: 12px;
    color: #a0a0a0;
  }

  @media (max-width: 480px) {
    #at-toast-container { bottom: 16px; right: 16px; left: 16px; }
    .at-toast { min-width: 0; max-width: 100%; }
  }
{% endstylesheet %}

<script>
  (function () {
    var sectionId = '{{ section.id }}';
    var track = document.getElementById('pgrid-track-' + sectionId);

    /* ── Carousel ── */
    var nextBtn = document.querySelector('[data-carousel-next="' + sectionId + '"]');
    var prevBtn = document.querySelector('[data-carousel-prev="' + sectionId + '"]');
    if (nextBtn) nextBtn.addEventListener('click', function () {
      if (track) track.scrollBy({ left: 305, behavior: 'smooth' });
    });
    if (prevBtn) prevBtn.addEventListener('click', function () {
      if (track) track.scrollBy({ left: -305, behavior: 'smooth' });
    });

  })();
</script>

<script>
/* ── Global wishlist handler (runs once across all sections) ── */
if (!window._artisansWishInit) {
  window._artisansWishInit = true;
  var _WISH_KEY = 'artisans_wishlist';

  function _getWL() { try { return JSON.parse(localStorage.getItem(_WISH_KEY) || '[]'); } catch(e) { return []; } }
  function _saveWL(a) { localStorage.setItem(_WISH_KEY, JSON.stringify(a)); }
  function _inWL(id) { return _getWL().some(function(i){ return String(i.id) === String(id); }); }

  /* Event delegation — catches buttons from any section, any load order */
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.pcard__wish');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();
    var id = btn.dataset.id;
    if (!id) return;
    var list = _getWL();
    if (_inWL(id)) {
      _saveWL(list.filter(function(i){ return String(i.id) !== String(id); }));
      btn.classList.remove('pcard__wish--on');
    } else {
      list.push({ id: id, title: btn.dataset.title, price: btn.dataset.price, image: btn.dataset.image, url: btn.dataset.url });
      _saveWL(list);
      btn.classList.add('pcard__wish--on');
    }
  });

  /* Set initial visual state once the full DOM is ready */
  function _markSavedBtns() {
    document.querySelectorAll('.pcard__wish').forEach(function(btn) {
      if (_inWL(btn.dataset.id)) btn.classList.add('pcard__wish--on');
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', _markSavedBtns);
  } else {
    _markSavedBtns();
  }
}

/* ── Global add-to-cart handler with toast feedback (runs once) ── */
if (!window._artisansAtcInit) {
  window._artisansAtcInit = true;

  var _toastWrap = document.createElement('div');
  _toastWrap.id = 'at-toast-container';
  document.body.appendChild(_toastWrap);

  function _showToast(title) {
    var t = document.createElement('div');
    t.className = 'at-toast';
    t.innerHTML =
      '<div class="at-toast__icon">' +
        '<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17L4 12" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>' +
      '</div>' +
      '<div class="at-toast__text">' +
        '<span class="at-toast__title">' + (title || 'Item') + '</span>' +
        '<span class="at-toast__msg">Added to cart!</span>' +
      '</div>';
    _toastWrap.appendChild(t);
    requestAnimationFrame(function() {
      requestAnimationFrame(function() { t.classList.add('at-toast--in'); });
    });
    setTimeout(function() {
      t.classList.remove('at-toast--in');
      t.classList.add('at-toast--out');
      setTimeout(function() { if (t.parentNode) t.parentNode.removeChild(t); }, 400);
    }, 3000);
  }

  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.pcard__atc');
    if (!btn || btn.disabled) return;
    var variantId = btn.getAttribute('data-variant-id');
    if (!variantId) return;

    btn.disabled = true;
    var pcard = btn.closest('.pcard');
    var titleEl = pcard ? pcard.querySelector('.pcard__title') : null;
    var productTitle = titleEl ? titleEl.textContent.trim() : 'Item';

    var origHTML = btn.innerHTML;
    btn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17L4 12" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function(r) { return r.json(); })
    .then(function() {
      return fetch('/cart.js').then(function(r) { return r.json(); });
    })
    .then(function(cart) {
      document.querySelectorAll('.js-cart-badge').forEach(function(el) {
        el.textContent = cart.item_count;
        el.style.display = cart.item_count > 0 ? '' : 'none';
      });
      document.dispatchEvent(new CustomEvent('at:cart:refresh'));
      setTimeout(function() { btn.innerHTML = origHTML; btn.disabled = false; }, 2000);
    })
    .catch(function() { btn.innerHTML = origHTML; btn.disabled = false; });
  });
}
</script>

{% schema %}
{
  "name": "New Arrivals",
  "settings": [
    {
      "type": "text",
      "id": "heading_prefix",
      "label": "Heading – first word(s)",
      "default": "New"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading – decorated word (gets swirl)",
      "default": "Arrival"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Anyone can get dresses up and glamorous, but it is how people dress in their days off."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "New Arrivals"
    }
  ]
}
{% endschema %}
