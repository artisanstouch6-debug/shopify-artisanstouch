<div class="pgrid full-width" style="background-color: var(--accent, #f5e6da);">
  <div class="pgrid__inner">
    <div class="pgrid__header">
      <div class="pgrid__title-wrap">
        <h2 class="pgrid__title">{{ section.settings.heading }}</h2>
      </div>
      <div class="pgrid__subtitle-row">
        <p class="pgrid__subtitle">{{ section.settings.subheading }}</p>
        <div class="pgrid__nav">
          <button class="pgrid__nav-btn pgrid__nav-btn--prev" aria-label="Previous" data-carousel-prev="{{ section.id }}">
            <svg width="50" height="50" viewBox="0 0 50 50" fill="none">
              <circle cx="25" cy="25" r="24" stroke="#828282" stroke-width="1.5"/>
              <path d="M28 17L20 25L28 33" stroke="#828282" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="pgrid__nav-btn pgrid__nav-btn--next" aria-label="Next" data-carousel-next="{{ section.id }}">
            <svg width="50" height="50" viewBox="0 0 50 50" fill="none">
              <circle cx="25" cy="25" r="24" stroke="#333" stroke-width="1.5"/>
              <path d="M22 17L30 25L22 33" stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="pgrid__track" id="pgrid-track-{{ section.id }}">
      {%- assign featured_collection = collections[section.settings.collection] -%}
      {%- if featured_collection != blank -%}
        {%- for product in featured_collection.products limit: section.settings.products_count -%}
          <div class="pcard">
            <a href="{{ product.url }}" class="pcard__image-link">
              {%- if product.featured_image -%}
                {{ product.featured_image | image_url: width: 285, height: 285, crop: 'center' | image_tag: class: 'pcard__img', loading: 'lazy', alt: product.featured_image.alt | default: product.title }}
              {%- else -%}
                <div class="pcard__img pcard__img--placeholder">{{ 'image' | placeholder_svg_tag }}</div>
              {%- endif -%}
            </a>
            <div class="pcard__info">
              <div class="pcard__row">
                <a href="{{ product.url }}" class="pcard__title">{{ product.title }}</a>
                <div class="pcard__actions">
                  <button class="pcard__action-btn" aria-label="Wishlist">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <a href="{{ product.url }}" class="pcard__action-btn" aria-label="View product">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M6 2L3 6V20C3 21.1 3.9 22 5 22H19C20.1 22 21 21.1 21 20V6L18 2H6Z" stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M3 6H21" stroke="#333" stroke-width="1.5" stroke-linecap="round"/>
                      <path d="M16 10C16 12.2 14.2 14 12 14C9.8 14 8 12.2 8 10" stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </div>
              </div>
              <p class="pcard__price">{{ product.price | money }}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="pcard">
            <div class="pcard__img pcard__img--placeholder">{{ 'product-' | append: i | placeholder_svg_tag }}</div>
            <div class="pcard__info">
              <div class="pcard__row">
                <span class="pcard__title">Sample Product {{ i }}</span>
                <div class="pcard__actions">
                  <button class="pcard__action-btn" aria-label="Wishlist">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
              </div>
              <p class="pcard__price">LKR 0.00</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .pgrid {
    width: 100%;
  }

  .pgrid__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 52px 120px;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .pgrid__header {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pgrid__title-wrap {
    position: relative;
    display: inline-block;
  }

  .pgrid__title {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 600;
    color: #000;
    margin: 0;
  }

  .pgrid__subtitle-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .pgrid__subtitle {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--gray, #828282);
    margin: 0;
    max-width: 530px;
  }

  .pgrid__nav {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-shrink: 0;
  }

  .pgrid__nav-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
  }

  .pgrid__nav-btn:hover { opacity: 0.7; }

  .pgrid__track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .pgrid__track::-webkit-scrollbar { display: none; }

  .pcard {
    flex: 0 0 285px;
    display: flex;
    flex-direction: column;
    gap: 17px;
    scroll-snap-align: start;
  }

  .pcard__image-link {
    display: block;
    width: 285px;
    height: 285px;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    flex-shrink: 0;
  }

  .pcard__img {
    width: 285px;
    height: 285px;
    object-fit: cover;
    border-radius: 12px;
    display: block;
    transition: transform 0.3s;
  }

  .pcard__image-link:hover .pcard__img { transform: scale(1.03); }

  .pcard__img--placeholder {
    background: #f0e8e8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pcard__img--placeholder svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .pcard__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pcard__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .pcard__title {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    color: #000;
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
  }

  .pcard__actions {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }

  .pcard__action-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
    text-decoration: none;
  }

  .pcard__action-btn:hover { opacity: 0.6; }

  .pcard__price {
    font-family: var(--font-body);
    font-size: 16px;
    color: #000;
    margin: 0;
    font-weight: 400;
  }

  @media (max-width: 1100px) {
    .pgrid__inner { padding: 40px 40px; }
  }

  @media (max-width: 768px) {
    .pgrid__inner { padding: 40px 20px; }
    .pcard { flex: 0 0 240px; }
    .pcard__image-link, .pcard__img { width: 240px; height: 240px; }
  }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('[data-carousel-next]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-carousel-next');
      const track = document.getElementById('pgrid-track-' + id);
      if (track) track.scrollBy({ left: 305, behavior: 'smooth' });
    });
  });
  document.querySelectorAll('[data-carousel-prev]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-carousel-prev');
      const track = document.getElementById('pgrid-track-' + id);
      if (track) track.scrollBy({ left: -305, behavior: 'smooth' });
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "New Arrivals",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "New Arrival"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Anyone can get dresses up and glamorous, but it is how people dress in their days off."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "New Arrivals"
    }
  ]
}
{% endschema %}
