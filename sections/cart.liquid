{% comment %}
  Cart page — custom UI matching Artisans Touch design
{% endcomment %}

<!-- ── Cart Hero ───────────────────────────────── -->
<section class="cart-hero full-width">
  {%- if section.settings.hero_image != blank -%}
    {{ section.settings.hero_image | image_url: width: 1800 | image_tag:
        class: 'cart-hero__bg',
        loading: 'eager',
        fetchpriority: 'high',
        alt: '' }}
  {%- else -%}
    <div class="cart-hero__bg cart-hero__bg--empty"></div>
  {%- endif -%}
  <div class="cart-hero__overlay"></div>
  <div class="cart-hero__text">
    <h1 class="cart-hero__title">Shopping Cart</h1>
  </div>
</section>

<!-- ── Cart Body ───────────────────────────────── -->
<section class="cart-page full-width">
  <div class="cart-page__inner">

  {%- if cart.item_count == 0 -%}
      <div class="cart-empty">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" stroke="#ccc" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="3" y1="6" x2="21" y2="6" stroke="#ccc" stroke-width="1.5" stroke-linecap="round"/><path d="M16 10a4 4 0 0 1-8 0" stroke="#ccc" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <p class="cart-empty__msg">Your cart is empty</p>
        <a href="{{ routes.all_products_collection_url }}" class="cart-empty__cta">Continue Shopping</a>
      </div>

    {%- else -%}
      <form action="/cart/checkout" method="post" id="cart-form">

        <div class="cart-layout">

          <!-- Items list -->
          <div class="cart-items">
            <div class="cart-items__line"></div>

            {%- for item in cart.items -%}
              <div class="cart-item" data-line="{{ forloop.index }}">

                <!-- Thumbnail -->
                <a href="{{ item.url }}" class="cart-item__img-wrap">
                  {%- if item.image -%}
                    {{ item.image | image_url: width: 200, height: 200, crop: 'center' | image_tag: loading: 'lazy', alt: item.product.title, class: 'cart-item__img' }}
                  {%- else -%}
                    <div class="cart-item__img-placeholder"></div>
                  {%- endif -%}
                </a>

                <!-- Info -->
                <div class="cart-item__info">
                  <a href="{{ item.url }}" class="cart-item__name">{{ item.product.title }}</a>
                  {%- unless item.variant.title == 'Default Title' -%}
                    <p class="cart-item__variant">{{ item.variant.title }}</p>
                  {%- endunless -%}

                  <!-- Qty controls -->
                  <div class="cart-item__qty-row">
                    <span class="cart-item__qty-label">Qty:</span>
                    <div class="cart-item__qty">
                      <button type="button" class="cart-qty__btn cart-qty__btn--minus" data-line="{{ forloop.index }}" aria-label="Decrease quantity">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12H19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                      </button>
                      <span class="cart-qty__num" id="cart-qty-{{ forloop.index }}">{{ item.quantity }}</span>
                      <input type="hidden" name="updates[]" class="cart-qty__input" id="cart-qty-input-{{ forloop.index }}" value="{{ item.quantity }}">
                      <button type="button" class="cart-qty__btn cart-qty__btn--plus" data-line="{{ forloop.index }}" aria-label="Increase quantity">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 5V19M5 12H19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                      </button>
                    </div>
                  </div>
                  <p class="cart-item__unit-price" id="cart-item-unit-{{ forloop.index }}" data-unit-price="{{ item.price }}">
                    {{ item.quantity }} &times; {{ item.price | money }}
                  </p>
                </div>

                <!-- Price + Remove -->
                <div class="cart-item__right">
                  <p class="cart-item__price" id="cart-item-price-{{ forloop.index }}">{{ item.line_price | money }}</p>
                  <a href="{{ item.url_to_remove }}" class="cart-item__remove" aria-label="Remove {{ item.product.title }}">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><polyline points="3 6 5 6 21 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 11v6M14 11v6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                </div>

              </div>
              <div class="cart-items__line"></div>
            {%- endfor -%}
          </div>

          <!-- Summary -->
          <div class="cart-summary">
            <div class="cart-summary__row">
              <span class="cart-summary__label">Total Amount</span>
              <span class="cart-summary__val" id="cart-total-amount">{{ cart.total_price | money }}</span>
            </div>
            <div class="cart-summary__row">
              <span class="cart-summary__label">Shipping Fee</span>
              <span class="cart-summary__val cart-summary__val--muted">Calculated at checkout</span>
            </div>
            <div class="cart-summary__row">
              <span class="cart-summary__label">Estimated Taxes</span>
              <span class="cart-summary__val cart-summary__val--muted">Calculated at checkout</span>
            </div>
            <div class="cart-summary__divider"></div>
            <div class="cart-summary__row cart-summary__row--total">
              <span class="cart-summary__label cart-summary__label--bold">Sub Total Amount</span>
              <span class="cart-summary__val cart-summary__val--bold" id="cart-subtotal">{{ cart.total_price | money }}</span>
            </div>

            <div class="cart-summary__actions">
              <button type="submit" class="cart-checkout-btn">Proceed to Checkout</button>
              <a href="{{ routes.all_products_collection_url }}" class="cart-continue-link">Continue Shopping</a>
            </div>
          </div>

        </div><!-- /cart-layout -->
      </form>
    {%- endif -%}

  </div>
</section>

<script>
(function () {
  var moneyFormat = {{ shop.money_format | json }};

  function formatMoney(cents) {
    return moneyFormat
      .replace(/\{\{amount\}\}/g, (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ','))
      .replace(/\{\{amount_no_decimals\}\}/g, Math.round(cents / 100).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ','));
  }

  document.querySelectorAll('.cart-qty__btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var line  = parseInt(btn.dataset.line, 10);
      var numEl = document.getElementById('cart-qty-' + line);
      var inp   = document.getElementById('cart-qty-input-' + line);
      var val   = parseInt(inp.value, 10);

      if (btn.classList.contains('cart-qty__btn--minus')) {
        val = Math.max(0, val - 1);
      } else {
        val = val + 1;
      }

      inp.value         = val;
      numEl.textContent = val;

      /* Update qty × unit price breakdown immediately */
      var unitEl = document.getElementById('cart-item-unit-' + line);
      if (unitEl) {
        var unitPrice = parseInt(unitEl.dataset.unitPrice, 10);
        unitEl.textContent = val + ' × ' + formatMoney(unitPrice);
      }

      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: line, quantity: val })
      })
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        /* Update the changed item's line price */
        var priceEl = document.getElementById('cart-item-price-' + line);
        if (priceEl && cart.items[line - 1]) {
          priceEl.textContent = formatMoney(cart.items[line - 1].line_price);
        }

        /* Update Total Amount and Sub Total Amount */
        var totalEl    = document.getElementById('cart-total-amount');
        var subtotalEl = document.getElementById('cart-subtotal');
        if (totalEl)    totalEl.textContent    = formatMoney(cart.total_price);
        if (subtotalEl) subtotalEl.textContent = formatMoney(cart.total_price);

        if (val === 0) { location.reload(); }
      });
    });
  });
})();
</script>

{% stylesheet %}
/* ── Cart page background ───────────────────────── */
body.template-cart {
  background: #fff8f8;
  padding-top: 0 !important;
}

/* ── Hero ────────────────────────────────────────── */
.cart-hero {
  position: relative;
  height: 65vh;
  min-height: 440px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-hero__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center center;
  display: block;
}

.cart-hero__bg--empty { background: #1a1a1a; }

.cart-hero__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.52);
}

.cart-hero__text {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 0 24px;
}

.cart-hero__title {
  font-family: var(--font-heading);
  font-size: 72px;
  font-weight: 400;
  color: #fff;
  margin: 0;
  line-height: 1.1;
  letter-spacing: 0.02em;
}

/* ── Cart body section ───────────────────────────── */
.cart-page {
  min-height: 60vh;
  background: #fff8f8;
}

.cart-page__inner {
  max-width: 1440px;
  width: 100%;
  box-sizing: border-box;
  margin: 0 auto;
  padding: 64px 120px 100px;
}

/* ── Empty state ─────────────────────────────────── */
.cart-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
  padding: 80px 0;
  text-align: center;
}

.cart-empty__msg {
  font-family: var(--font-body);
  font-size: 18px;
  color: #888;
  margin: 0;
}

.cart-empty__cta {
  display: inline-block;
  padding: 14px 40px;
  border: 1.5px solid var(--coral-pink, #ff9696);
  border-radius: 26px;
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 600;
  color: var(--coral-pink, #ff9696);
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}

.cart-empty__cta:hover {
  background: var(--coral-pink, #ff9696);
  color: #fff;
}

/* ── Two-column layout ───────────────────────────── */
.cart-layout {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* ── Items list ──────────────────────────────────── */
.cart-items {
  width: 100%;
}

.cart-items__line {
  height: 1px;
  background: #ececec;
}

/* ── Single cart item ────────────────────────────── */
.cart-item {
  display: flex;
  align-items: center;
  gap: 24px;
  padding: 24px 0;
}

/* Thumbnail */
.cart-item__img-wrap {
  flex-shrink: 0;
  width: 108px;
  height: 108px;
  border-radius: 12px;
  overflow: hidden;
  background: #f0ebe8;
  display: block;
}

.cart-item__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.cart-item__img-placeholder {
  width: 100%;
  height: 100%;
  background: #f0ebe8;
}

/* Info column */
.cart-item__info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.cart-item__name {
  font-family: var(--font-body);
  font-size: 16px;
  font-weight: 600;
  color: #111;
  text-decoration: none;
  line-height: 1.3;
}

.cart-item__name:hover { color: var(--coral-pink, #ff9696); }

.cart-item__variant {
  font-family: var(--font-body);
  font-size: 13px;
  color: #999;
  margin: 0;
}

/* Qty row */
.cart-item__qty-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 4px;
}

.cart-item__qty-label {
  font-family: var(--font-body);
  font-size: 14px;
  color: #999;
}

.cart-item__qty {
  display: flex;
  align-items: center;
  gap: 14px;
}

.cart-qty__btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--coral-pink, #ff9696);
  transition: opacity 0.2s;
}

.cart-qty__btn:hover { opacity: 0.65; }

.cart-qty__num {
  font-family: var(--font-body);
  font-size: 16px;
  font-weight: 700;
  color: #111;
  min-width: 22px;
  text-align: center;
}

/* Unit price breakdown (qty × unit) */
.cart-item__unit-price {
  font-family: var(--font-body);
  font-size: 13px;
  color: #999;
  margin: 2px 0 0;
}

/* Price + remove (right side) */
.cart-item__right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16px;
  flex-shrink: 0;
}

.cart-item__price {
  font-family: var(--font-body);
  font-size: 16px;
  font-weight: 700;
  color: #111;
  margin: 0;
}

.cart-item__remove {
  color: var(--coral-pink, #ff9696);
  display: flex;
  align-items: center;
  transition: opacity 0.2s;
}

.cart-item__remove:hover { opacity: 0.65; }

/* ── Summary ─────────────────────────────────────── */
.cart-summary {
  margin-top: 40px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.cart-summary__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.cart-summary__label {
  font-family: var(--font-body);
  font-size: 15px;
  color: #666;
}

.cart-summary__label--bold {
  font-weight: 700;
  color: #111;
  font-size: 16px;
}

.cart-summary__val {
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 600;
  color: #111;
}

.cart-summary__val--muted {
  font-weight: 400;
  color: #999;
  font-size: 14px;
}

.cart-summary__val--bold {
  font-size: 22px;
  font-weight: 800;
  letter-spacing: -0.3px;
  color: #111;
}

.cart-summary__divider {
  height: 1px;
  background: #ececec;
  margin: 4px 0;
}

/* ── CTA buttons ─────────────────────────────────── */
.cart-summary__actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  margin-top: 24px;
}

.cart-checkout-btn {
  display: block;
  width: 100%;
  max-width: 360px;
  height: 54px;
  background: transparent;
  border: 1.8px solid var(--coral-pink, #ff9696);
  border-radius: 27px;
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 600;
  color: var(--coral-pink, #ff9696);
  cursor: pointer;
  transition: background 0.2s, color 0.2s, transform 0.15s;
  letter-spacing: 0.2px;
}

.cart-checkout-btn:hover {
  background: var(--coral-pink, #ff9696);
  color: #fff;
  transform: translateY(-1px);
}

.cart-continue-link {
  font-family: var(--font-body);
  font-size: 13px;
  color: #666;
  text-decoration: none;
  transition: color 0.2s;
}

.cart-continue-link:hover { color: var(--coral-pink, #ff9696); }

/* ── Responsive ──────────────────────────────────── */
@media (max-width: 1200px) {
  .cart-page__inner { padding: 48px 60px 80px; }
  .cart-hero__title { font-size: 56px; }
}

@media (max-width: 960px) {
  .cart-page__inner { padding: 40px 32px 64px; }
  .cart-item__img-wrap { width: 88px; height: 88px; }
  .cart-hero { min-height: 320px; }
  .cart-hero__title { font-size: 44px; }
}

@media (max-width: 600px) {
  .cart-page__inner { padding: 28px 16px 56px; }
  .cart-item { gap: 16px; }
  .cart-item__img-wrap { width: 72px; height: 72px; }
  .cart-item__name { font-size: 14px; }
  .cart-item__price { font-size: 14px; }
  .cart-checkout-btn { max-width: 100%; }
  .cart-hero { min-height: 240px; }
  .cart-hero__title { font-size: 32px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image"
    }
  ]
}
{% endschema %}
