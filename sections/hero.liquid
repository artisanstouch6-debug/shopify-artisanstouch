<div class="hero full-width" id="hero-{{ section.id }}">

  <div class="hero__carousel">
    {%- assign default_slides = 'hero-bg.jpg,hero-slide-2.jpg,hero-slide-3.jpg' | split: ',' -%}
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        <div class="hero__slide{% if forloop.first %} hero__slide--active{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.image -%}
            {{ block.settings.image | image_url: width: 2000 | image_tag: class: 'hero__slide-img', loading: forloop.first | default: 'lazy', fetchpriority: forloop.first | default: 'auto', alt: '' }}
          {%- else -%}
            {%- assign default_img = default_slides[forloop.index0] | default: 'hero-bg.jpg' -%}
            <img src="{{ default_img | asset_url }}" alt="" class="hero__slide-img"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              fetchpriority="{% if forloop.first %}high{% else %}auto{% endif %}">
          {%- endif -%}
          <div class="hero__overlay"></div>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="hero__slide hero__slide--active">
        <img src="{{ 'hero-bg.jpg' | asset_url }}" alt="" class="hero__slide-img" loading="eager" fetchpriority="high">
        <div class="hero__overlay"></div>
      </div>
    {%- endif -%}
  </div>

  <div class="hero__content">
    <div class="hero__text-group">
      <h1 class="hero__heading hero-anim hero-anim--left">{{ section.settings.heading }}</h1>
      <div class="hero__row">
        <a href="{{ section.settings.button_url }}" class="hero__btn hero-anim hero-anim--up" style="--delay:.5s">
          {{ section.settings.button_label }}
          <svg width="20" height="20" viewBox="0 0 50 50" fill="none" aria-hidden="true" style="transform:rotate(90deg);flex-shrink:0;">
            <path d="M10.4167 16.6667C11.9625 16.6667 14.2708 15.1396 16.2083 13.5937C18.7083 11.6062 20.8896 9.23125 22.5542 6.50833C23.8021 4.46667 25 1.99167 25 0M25 0C25 1.99167 26.1979 4.46875 27.4458 6.50833C29.1125 9.23125 31.2937 11.6062 33.7896 13.5937C35.7292 15.1396 38.0417 16.6667 39.5833 16.6667M25 0V50" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
          </svg>
        </a>
        {%- if section.settings.subheading != blank -%}
          <p class="hero__subheading hero-anim hero-anim--right" style="--delay:.3s">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    </div>

    <div class="hero__bottom">
      <div class="hero__stats hero-anim hero-anim--up" style="--delay:.6s">
        <div class="hero__stat">
          <span class="hero__stat-num">{{ section.settings.stat_1_number }}</span>
          <span class="hero__stat-label">{{ section.settings.stat_1_label }}</span>
        </div>
        <div class="hero__divider" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">{{ section.settings.stat_2_number }}</span>
          <span class="hero__stat-label">{{ section.settings.stat_2_label }}</span>
        </div>
        <div class="hero__divider" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">{{ section.settings.stat_3_number }}</span>
          <span class="hero__stat-label">{{ section.settings.stat_3_label }}</span>
        </div>
      </div>

      <a href="{{ section.settings.explore_url }}" class="hero__explore hero-anim hero-anim--up" style="--delay:.7s">
        <div class="hero__explore-btn" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 50 50" fill="none" style="transform:rotate(180deg);flex-shrink:0;">
            <path d="M10.4167 16.6667C11.9625 16.6667 14.2708 15.1396 16.2083 13.5937C18.7083 11.6062 20.8896 9.23125 22.5542 6.50833C23.8021 4.46667 25 1.99167 25 0M25 0C25 1.99167 26.1979 4.46875 27.4458 6.50833C29.1125 9.23125 31.2937 11.6062 33.7896 13.5937C35.7292 15.1396 38.0417 16.6667 39.5833 16.6667M25 0V50" stroke="white" stroke-width="4" stroke-linecap="round"/>
          </svg>
        </div>
        <span>{{ section.settings.explore_label }}</span>
      </a>
    </div>
  </div>

  {%- assign slide_count = section.blocks.size -%}
  {%- if slide_count > 1 -%}
    <div class="hero__dots" role="tablist" aria-label="Slideshow navigation">
      {%- for i in (1..slide_count) -%}
        <button class="hero__dot{% if forloop.first %} hero__dot--active{% endif %}"
                role="tab"
                aria-label="Slide {{ i }}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                data-slide="{{ forloop.index0 }}">
        </button>
      {%- endfor -%}
    </div>
  {%- else -%}
    <div class="hero__dots" aria-hidden="true">
      <span class="hero__dot hero__dot--active"></span>
      <span class="hero__dot"></span>
      <span class="hero__dot"></span>
    </div>
  {%- endif -%}

</div>

<script>
(function () {
  var heroEl  = document.getElementById('hero-{{ section.id }}');
  if (!heroEl) return;

  var slides  = heroEl.querySelectorAll('.hero__slide');
  var dots    = heroEl.querySelectorAll('.hero__dot[data-slide]');
  var current = 0;
  var speed   = {{ section.settings.autoplay_speed | default: 5000 }};
  var doAuto  = {{ section.settings.autoplay | default: true }};
  var timer;

  function goTo(idx) {
    slides[current].classList.remove('hero__slide--active');
    if (dots[current]) {
      dots[current].classList.remove('hero__dot--active');
      dots[current].setAttribute('aria-selected', 'false');
    }
    current = (idx + slides.length) % slides.length;
    slides[current].classList.add('hero__slide--active');
    if (dots[current]) {
      dots[current].classList.add('hero__dot--active');
      dots[current].setAttribute('aria-selected', 'true');
    }
  }

  function startTimer() {
    clearInterval(timer);
    if (doAuto) {
      timer = setInterval(function () { goTo(current + 1); }, speed);
    }
  }

  /* Dot click navigation */
  dots.forEach(function (dot) {
    dot.addEventListener('click', function () {
      goTo(parseInt(dot.getAttribute('data-slide'), 10));
      startTimer();
    });
  });

  /* Start autoplay only if there are multiple slides */
  if (slides.length > 1) {
    startTimer();
  }

  /* Scroll-reveal for .reveal elements on the page */
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.reveal').forEach(function (el) { obs.observe(el); });
  } else {
    document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('revealed'); });
  }
})();
</script>

{% stylesheet %}
  .hero {
    position: relative;
    height: 943px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    color: white;
  }

  .hero__carousel {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1s ease;
  }

  .hero__slide--active { opacity: 1; }

  .hero__slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.2);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    /* Figma: content y=203 to y=857, bottom gap = 943-857 = 86px */
    padding: 203px 120px 86px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex: 1;
    max-width: 1440px;
    margin: 0 auto;
    width: 100%;
  }

  .hero__text-group {
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .hero__heading {
    font-family: var(--font-heading);
    font-size: 64px;
    font-weight: 400;
    line-height: 1.2;
    color: white;
    max-width: 793px;
    margin: 0;
  }

  .hero__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 40px;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 1px solid var(--coral-pink, #ff9696);
    color: var(--coral-pink, #ff9696);
    padding: 10px 22px;
    border-radius: 24px;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.08em;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background-color 0.25s, color 0.25s;
  }

  .hero__btn:hover {
    background-color: var(--coral-pink, #ff9696);
    color: white;
  }

  .hero__subheading {
    font-family: var(--font-heading);
    font-size: 16px;
    color: var(--light-c-pink, #ffc4c4);
    text-align: right;
    max-width: 579px;
    line-height: 1.6;
    margin: 0;
  }

  .hero__bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    width: 100%;
  }

  .hero__stats {
    display: flex;
    align-items: flex-end;
    gap: 48px;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .hero__stat-num {
    font-family: var(--font-heading);
    font-size: 90px;
    line-height: 1;
    color: var(--light-c-pink, #ffc4c4);
    font-weight: 400;
  }

  .hero__stat-label {
    font-family: var(--font-body);
    font-size: 16px;
    color: white;
    white-space: nowrap;
    margin-top:.7rem;
  }

  .hero__divider {
    width: 1px;
    height: 60px;
    background: rgba(255, 255, 255, 0.35);
    flex-shrink: 0;
    align-self: flex-end;
    margin-bottom: 35px;
  }

  .hero__explore {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: white;
    font-family: var(--font-body);
    font-size: 14px;
    width: 90px;
    text-align: center;
    flex-shrink: 0;
  }

  .hero__explore-btn {
    width: 90px;
    height: 90px;
    border-radius: 100px;
    background-color: rgba(255, 150, 150, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.25s;
  }

  .hero__explore:hover .hero__explore-btn {
    background-color: rgba(255, 150, 150, 0.8);
  }

  .hero__dots {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 2;
    align-items: center;
  }

  .hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.4);
    display: block;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: width 0.3s, background-color 0.3s, border-radius 0.3s;
  }

  .hero__dot--active {
    background-color: white;
    width: 32px;
    border-radius: 4px;
  }

  /* ── Hero entrance animations — pure CSS, no JS needed ─────────── */
  @keyframes heroLeft {
    from { opacity: 0; transform: translateX(-40px); }
    to   { opacity: 1; transform: none; }
  }
  @keyframes heroRight {
    from { opacity: 0; transform: translateX(40px); }
    to   { opacity: 1; transform: none; }
  }
  @keyframes heroUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: none; }
  }

  .hero-anim--left  { animation: heroLeft  0.8s ease both; animation-delay: var(--delay, 0.2s); }
  .hero-anim--right { animation: heroRight 0.8s ease both; animation-delay: var(--delay, 0.3s); }
  .hero-anim--up    { animation: heroUp    0.7s ease both; animation-delay: var(--delay, 0.5s); }

  /* ── Scroll-reveal (shared across all sections) ──────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.7s ease, transform 0.7s ease;
    transition-delay: var(--reveal-delay, 0s);
  }
  .reveal.revealed {
    opacity: 1;
    transform: none;
  }

  @media (max-width: 1100px) {
    .hero { height: auto; min-height: 700px; }
    .hero__heading { font-size: 44px; }
    .hero__stat-num { font-size: 74px; }
    .hero__content { padding: 160px 40px 60px; }
    .hero__subheading { display: none; }
    .hero__explore { display: none; }
  }

  @media (max-width: 768px) {
    .hero { min-height: 600px; }
    .hero__heading { font-size: 32px; }
    .hero__content { padding: 120px 20px 60px; }
    .hero__stat-num { font-size: 58px; }
    .hero__stats { gap: 20px; }
    .hero__stat-label { font-size: 13px; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var heroEl = document.getElementById('hero-{{ section.id }}');
    if (!heroEl) return;

    /* Carousel */
    var slides = heroEl.querySelectorAll('.hero__slide');
    var dots   = heroEl.querySelectorAll('.hero__dot');
    if (slides.length < 2) {
      bootReveal();
      return;
    }

    var current = 0;
    var timer;
    var speed = {{ section.settings.autoplay_speed | default: 5000 }};
    var autoplay = {{ section.settings.autoplay | default: true }};

    function goTo(idx) {
      slides[current].classList.remove('hero__slide--active');
      if (dots[current]) {
        dots[current].classList.remove('hero__dot--active');
        dots[current].setAttribute('aria-selected', 'false');
      }
      current = (idx + slides.length) % slides.length;
      slides[current].classList.add('hero__slide--active');
      if (dots[current]) {
        dots[current].classList.add('hero__dot--active');
        dots[current].setAttribute('aria-selected', 'true');
      }
    }

    function startTimer() {
      clearInterval(timer);
      if (autoplay) timer = setInterval(function () { goTo(current + 1); }, speed);
    }

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        goTo(parseInt(dot.getAttribute('data-slide'), 10));
        startTimer();
      });
    });

    startTimer();
    bootReveal();

    /* Scroll-reveal for all .reveal elements on the page */
    function bootReveal() {
      if (!('IntersectionObserver' in window)) {
        document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('revealed'); });
        return;
      }
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      document.querySelectorAll('.reveal').forEach(function (el) { obs.observe(el); });
    }
  })();
{% endjavascript %}

