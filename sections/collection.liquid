{%- comment -%}
  Collection page — banner (collection image/title/desc) + filterable product grid.
  Tags are filtered server-side via URL (/collections/handle/tag).
  Price range filters client-side by hiding cards outside the selected range.
{%- endcomment -%}

{%- assign per_page = section.settings.products_per_page | default: 12 -%}
{%- assign price_max_cents = section.settings.price_max | times: 100 -%}

{%- comment -%} Build base URL preserving any active tag for sort links {%- endcomment -%}
{%- assign base_url = collection.url -%}
{%- if current_tags.size > 0 -%}
  {%- assign joined_tags = current_tags | join: '+' -%}
  {%- assign base_url = collection.url | append: '/' | append: joined_tags -%}
{%- endif -%}

<!-- ── Remove body padding so banner starts at the very top ── -->
<style>
  body.template-collection {
    padding-top: 0 !important;
  }
</style>

<!-- ── Collection Banner ─────────────────────────────── -->
<section class="coll-banner full-width">
  {%- if collection.image -%}
    {{ collection.image | image_url: width: 2000 | image_tag: class: 'coll-banner__bg', loading: 'eager', fetchpriority: 'high', alt: '' }}
  {%- elsif section.settings.fallback_image -%}
    {{ section.settings.fallback_image | image_url: width: 2000 | image_tag: class: 'coll-banner__bg', loading: 'eager', fetchpriority: 'high', alt: '' }}
  {%- else -%}
    <img src="{{ 'hero-bg.jpg' | asset_url }}" alt="" class="coll-banner__bg" loading="eager">
  {%- endif -%}
  <div class="coll-banner__overlay"></div>
  <div class="coll-banner__text">
    <h1 class="coll-banner__title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="coll-banner__desc">{{ collection.description | strip_html }}</p>
    {%- endif -%}
  </div>
</section>

<!-- ── Products Section ──────────────────────────────── -->
{% paginate collection.products by per_page %}
<section class="coll-main full-width">
  <div class="coll-main__inner">

    <!-- Section heading — swirl only under the last word -->
    {%- assign coll_words = collection.title | split: ' ' -%}
    {%- assign last_word  = coll_words | last -%}
    {%- assign pre_words  = collection.title | split: last_word | first | strip -%}
    <div class="coll-section-head">
      <h2 class="coll-section-title">
        {{ section.settings.heading_prefix }}
        {%- if pre_words != blank %}&nbsp;{{ pre_words }}{%- endif -%}
        &nbsp;<span class="coll-section-title__hl">{{ last_word }}<img src="{{ 'heading-swirl.svg' | asset_url }}" class="coll-section-title__swirl" alt="" aria-hidden="true"></span>
      </h2>
    </div>

    <!-- Filter bar: tags (left) + price range (right) -->
    {%- if collection.all_tags.size > 0 or section.settings.show_price_filter -%}
    <div class="coll-filterbar">

      {%- if collection.all_tags.size > 0 -%}
      <div class="coll-filterbar__tags">
        <a href="{{ collection.url }}{% if collection.sort_by != blank %}?sort_by={{ collection.sort_by }}{% endif %}"
           class="coll-pill{% unless current_tags.size > 0 %} coll-pill--active{% endunless %}">All</a>
        {%- for tag in collection.all_tags -%}
          <a href="{{ collection.url }}/{{ tag | handleize }}{% if collection.sort_by != blank %}?sort_by={{ collection.sort_by }}{% endif %}"
             class="coll-pill{% if current_tags contains tag %} coll-pill--active{% endif %}">{{ tag }}</a>
        {%- endfor -%}
      </div>
      {%- endif -%}

      {%- if section.settings.show_price_filter -%}
      <div class="coll-filterbar__price"
           id="coll-price-{{ section.id }}"
           data-max="{{ price_max_cents }}"
           data-target="coll-grid-{{ section.id }}"
           data-count="coll-count-{{ section.id }}">
        <p class="coll-price-label">Filter by Price</p>
        <p class="coll-price-display">
          Price:&nbsp;<span class="js-pmin">{{ 0 | money_without_trailing_zeros }}</span>&nbsp;–&nbsp;<span class="js-pmax">{{ price_max_cents | money_without_trailing_zeros }}</span>
        </p>
        <div class="coll-slider-wrap">
          <div class="coll-slider-track"></div>
          <div class="coll-slider-fill" id="coll-fill-{{ section.id }}"></div>
          <input type="range" class="coll-range js-range-min"
                 min="0" max="{{ price_max_cents }}" value="0" step="500"
                 aria-label="Minimum price">
          <input type="range" class="coll-range js-range-max"
                 min="0" max="{{ price_max_cents }}" value="{{ price_max_cents }}" step="500"
                 aria-label="Maximum price">
        </div>
      </div>
      {%- endif -%}

    </div>
    {%- endif -%}

    <!-- Controls: product count (left) + sort (right) -->
    <div class="coll-controls">
      <span class="coll-controls__count" id="coll-count-{{ section.id }}">{{ paginate.items }} Products</span>
      <div class="coll-sort-drop" id="coll-sort-{{ section.id }}">
        {%- assign sort_options = '' -%}
        {%- if collection.sort_by == 'created-descending' -%}{%- assign sort_label = 'Newest' -%}
        {%- elsif collection.sort_by == 'price-ascending' -%}{%- assign sort_label = 'Price: Low to High' -%}
        {%- elsif collection.sort_by == 'price-descending' -%}{%- assign sort_label = 'Price: High to Low' -%}
        {%- elsif collection.sort_by == 'title-ascending' -%}{%- assign sort_label = 'A – Z' -%}
        {%- elsif collection.sort_by == 'title-descending' -%}{%- assign sort_label = 'Z – A' -%}
        {%- else -%}{%- assign sort_label = 'Most Popular' -%}
        {%- endif -%}
        <button class="coll-sort-btn" aria-haspopup="listbox" aria-expanded="false">
          <span class="coll-sort-btn__label">{{ sort_label }}</span>
          <svg class="coll-sort-btn__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <ul class="coll-sort-list" role="listbox">
          <li class="coll-sort-option{% if collection.sort_by == 'best-selling' or collection.sort_by == blank %} coll-sort-option--active{% endif %}" role="option" data-url="{{ base_url }}?sort_by=best-selling">Most Popular</li>
          <li class="coll-sort-option{% if collection.sort_by == 'created-descending' %} coll-sort-option--active{% endif %}" role="option" data-url="{{ base_url }}?sort_by=created-descending">Newest</li>
          <li class="coll-sort-option{% if collection.sort_by == 'price-ascending' %} coll-sort-option--active{% endif %}" role="option" data-url="{{ base_url }}?sort_by=price-ascending">Price: Low to High</li>
          <li class="coll-sort-option{% if collection.sort_by == 'price-descending' %} coll-sort-option--active{% endif %}" role="option" data-url="{{ base_url }}?sort_by=price-descending">Price: High to Low</li>
          <li class="coll-sort-option{% if collection.sort_by == 'title-ascending' %} coll-sort-option--active{% endif %}" role="option" data-url="{{ base_url }}?sort_by=title-ascending">A – Z</li>
          <li class="coll-sort-option{% if collection.sort_by == 'title-descending' %} coll-sort-option--active{% endif %}" role="option" data-url="{{ base_url }}?sort_by=title-descending">Z – A</li>
        </ul>
      </div>
    </div>

    <!-- 4-column product grid -->
    <div class="coll-grid" id="coll-grid-{{ section.id }}">
      {%- for product in collection.products -%}
        <div class="coll-pcard" data-price="{{ product.price }}">
          <a href="{{ product.url }}" class="coll-pcard__link">
            <div class="coll-pcard__img-wrap">
              {%- if product.featured_image -%}
                {{ product.featured_image
                  | image_url: width: 600, height: 600, crop: 'center'
                  | image_tag: class: 'coll-pcard__img', loading: 'lazy', alt: product.featured_image.alt | default: product.title }}
              {%- else -%}
                <div class="coll-pcard__img--ph">{{ 'image' | placeholder_svg_tag }}</div>
              {%- endif -%}
            </div>
          </a>
          <div class="coll-pcard__info">
            <div class="coll-pcard__row">
              <a href="{{ product.url }}" class="coll-pcard__name">{{ product.title }}</a>
              <div class="coll-pcard__acts">
                <button class="coll-pcard__act-btn coll-pcard__wish"
                        aria-label="Add to wishlist"
                        data-id="{{ product.id }}"
                        data-title="{{ product.title | escape }}"
                        data-price="{{ product.price | money }}"
                        data-image="{{ product.featured_image | image_url: width: 300 }}"
                        data-url="{{ product.url }}">
                  <svg class="coll-wish-icon" width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12.62 20.8101C12.28 20.9301 11.72 20.9301 11.38 20.8101C8.48 19.8201 2 15.6901 2 8.6901C2 5.6001 4.49 3.1001 7.56 3.1001C9.38 3.1001 10.99 3.9801 12 5.3401C13.01 3.9801 14.63 3.1001 16.44 3.1001C19.51 3.1001 22 5.6001 22 8.6901C22 15.6901 15.52 19.8201 12.62 20.8101Z" stroke="black" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <button class="coll-pcard__act-btn coll-pcard__atc" aria-label="Add to cart" data-variant="{{ product.first_available_variant.id }}">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M7.5 7.67001V6.70001C7.5 4.45001 9.31 2.24001 11.56 2.03001C14.24 1.77001 16.5 3.88001 16.5 6.51001V7.89001" stroke="black" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M8.99999 22H15C19.02 22 19.74 20.39 19.95 18.43L20.7 12.43C20.97 9.99 20.27 8 16 8H7.99999C3.72999 8 3.02999 9.99 3.29999 12.43L4.04999 18.43C4.25999 20.39 4.97999 22 8.99999 22Z" stroke="black" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M15.4955 12H15.5045" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M8.49451 12H8.50349" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
            </div>
            <p class="coll-pcard__price">{{ product.price | money }}</p>
          </div>
        </div>
      {%- else -%}
        <p class="coll-empty">No products found in this collection.</p>
      {%- endfor -%}
    </div>

    <!-- Pagination -->
    {%- if paginate.pages > 1 -%}
    <nav class="coll-pagination" aria-label="Collection pagination">
      {%- if paginate.previous -%}
        <a href="{{ paginate.previous.url }}" class="coll-page-btn" aria-label="Previous page">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      {%- else -%}
        <span class="coll-page-btn coll-page-btn--disabled" aria-disabled="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      {%- endif -%}

      {%- for part in paginate.parts -%}
        {%- if part.is_link -%}
          <a href="{{ part.url }}" class="coll-page-num">{{ part.title }}</a>
        {%- elsif part.title == paginate.current_page -%}
          <span class="coll-page-num coll-page-num--active" aria-current="page">{{ part.title }}</span>
        {%- else -%}
          <span class="coll-page-num coll-page-num--gap">{{ part.title }}</span>
        {%- endif -%}
      {%- endfor -%}

      {%- if paginate.next -%}
        <a href="{{ paginate.next.url }}" class="coll-page-btn" aria-label="Next page">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      {%- else -%}
        <span class="coll-page-btn coll-page-btn--disabled" aria-disabled="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      {%- endif -%}
    </nav>
    {%- endif -%}

  </div>
</section>
{% endpaginate %}

<!-- ── Price range slider JS ────────────────────────── -->
<script>
(function () {
  var wrap = document.getElementById('coll-price-{{ section.id }}');
  if (!wrap) return;

  var fill       = document.getElementById('coll-fill-{{ section.id }}');
  var rangeMin   = wrap.querySelector('.js-range-min');
  var rangeMax   = wrap.querySelector('.js-range-max');
  var dispMin    = wrap.querySelector('.js-pmin');
  var dispMax    = wrap.querySelector('.js-pmax');
  var grid       = document.getElementById(wrap.dataset.target);
  var countEl    = document.getElementById(wrap.dataset.count);
  var priceMax   = parseInt(wrap.dataset.max, 10);

  function fmt(cents) {
    var amount = Math.round(cents / 100);
    return 'LKR ' + amount.toLocaleString();
  }

  function pct(val) { return (val / priceMax) * 100; }

  function updateFill() {
    var lo = parseInt(rangeMin.value, 10);
    var hi = parseInt(rangeMax.value, 10);
    fill.style.left  = pct(lo) + '%';
    fill.style.width = (pct(hi) - pct(lo)) + '%';
    dispMin.textContent = fmt(lo);
    dispMax.textContent = fmt(hi);
  }

  function filterCards() {
    if (!grid) return;
    var lo = parseInt(rangeMin.value, 10);
    var hi = parseInt(rangeMax.value, 10);
    var visible = 0;
    grid.querySelectorAll('.coll-pcard').forEach(function (card) {
      var p = parseInt(card.dataset.price, 10);
      var show = p >= lo && p <= hi;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (countEl) countEl.textContent = visible + ' Products';
  }

  rangeMin.addEventListener('input', function () {
    var lo = parseInt(rangeMin.value, 10);
    var hi = parseInt(rangeMax.value, 10);
    if (lo >= hi - 500) { rangeMin.value = Math.max(0, hi - 500); }
    updateFill();
    filterCards();
  });

  rangeMax.addEventListener('input', function () {
    var lo = parseInt(rangeMin.value, 10);
    var hi = parseInt(rangeMax.value, 10);
    if (hi <= lo + 500) { rangeMax.value = Math.min(priceMax, lo + 500); }
    updateFill();
    filterCards();
  });

  updateFill();
})();
</script>

<!-- ── Custom sort dropdown JS ──────────────────────── -->
<script>
(function () {
  var drop = document.getElementById('coll-sort-{{ section.id }}');
  if (!drop) return;

  var btn  = drop.querySelector('.coll-sort-btn');
  var list = drop.querySelector('.coll-sort-list');
  var label = drop.querySelector('.coll-sort-btn__label');

  function open()  { drop.classList.add('coll-sort-drop--open'); btn.setAttribute('aria-expanded', 'true'); }
  function close() { drop.classList.remove('coll-sort-drop--open'); btn.setAttribute('aria-expanded', 'false'); }
  function toggle() { drop.classList.contains('coll-sort-drop--open') ? close() : open(); }

  btn.addEventListener('click', function (e) { e.stopPropagation(); toggle(); });

  list.querySelectorAll('.coll-sort-option').forEach(function (opt) {
    opt.addEventListener('click', function () {
      label.textContent = opt.textContent;
      list.querySelectorAll('.coll-sort-option').forEach(function (o) { o.classList.remove('coll-sort-option--active'); });
      opt.classList.add('coll-sort-option--active');
      close();
      location.href = opt.dataset.url;
    });
  });

  document.addEventListener('click', function (e) {
    if (!drop.contains(e.target)) close();
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') close();
  });
})();
</script>

<!-- ── Add-to-cart JS ────────────────────────────────── -->
<script>
(function () {
  var grid = document.getElementById('coll-grid-{{ section.id }}');
  if (!grid) return;
  grid.querySelectorAll('.coll-pcard__atc').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var id = btn.dataset.variant;
      if (!id) return;
      btn.disabled = true;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id, quantity: 1 })
      })
      .then(function (r) { return r.json(); })
      .then(function () {
        document.dispatchEvent(new CustomEvent('cart:refresh'));
        btn.disabled = false;
      })
      .catch(function () { btn.disabled = false; });
    });
  });
})();
</script>

<script>
/* ── Wishlist ────────────────────────────────────── */
(function () {
  var WISH_KEY = 'artisans_wishlist';

  function getWishlist() {
    try { return JSON.parse(localStorage.getItem(WISH_KEY) || '[]'); } catch(e) { return []; }
  }
  function saveWishlist(arr) {
    localStorage.setItem(WISH_KEY, JSON.stringify(arr));
  }
  function isInWishlist(id) {
    return getWishlist().some(function(i) { return String(i.id) === String(id); });
  }

  document.querySelectorAll('.coll-pcard__wish').forEach(function (btn) {
    /* set initial filled state */
    if (isInWishlist(btn.dataset.id)) {
      btn.classList.add('coll-pcard__wish--on');
    }

    btn.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      var id   = btn.dataset.id;
      var list = getWishlist();
      if (isInWishlist(id)) {
        saveWishlist(list.filter(function(i) { return String(i.id) !== String(id); }));
        btn.classList.remove('coll-pcard__wish--on');
      } else {
        list.push({
          id:    id,
          title: btn.dataset.title,
          price: btn.dataset.price,
          image: btn.dataset.image,
          url:   btn.dataset.url
        });
        saveWishlist(list);
        btn.classList.add('coll-pcard__wish--on');
      }
    });
  });
})();
</script>

{% stylesheet %}
/* ── Banner ──────────────────────────────────────── */
.coll-banner {
  position: relative;
  height: 55vh;
  min-height: 320px;
  max-height: 500px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.coll-banner__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

.coll-banner__bg--empty {
  background: #2a1a1a;
}

.coll-banner__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.52);
}

.coll-banner__text {
  position: relative;
  z-index: 1;
  text-align: center;
  color: #fff;
  padding: 0 40px;
  max-width: 860px;
}

.coll-banner__title {
  font-family: var(--font-heading);
  font-size: 84px;
  font-weight: 400;
  line-height: 1.1;
  margin: 0 0 24px;
  color: #fff;
}

.coll-banner__desc {
  font-family: var(--font-body);
  font-size: 16px;
  line-height: 1.75;
  color: var(--light-c-pink, #ffc4c4);
  margin: 0;
  max-width: 560px;
  margin-inline: auto;
}

/* ── Main products section ───────────────────────── */
.coll-main {
  background: #fff;
  overflow: hidden;
}

.coll-main__inner {
  max-width: 1440px;
  width: 100%;
  box-sizing: border-box;
  margin: 0 auto;
  padding: 56px 80px 80px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

/* ── Section heading ─────────────────────────────── */
.coll-section-head {
  text-align: center;
  padding-bottom: 12px;
}

.coll-section-title {
  font-family: var(--font-heading);
  font-size: 40px;
  font-weight: 600;
  color: #000;
  margin: 0;
  display: inline-block;
}

.coll-section-title__hl {
  display: inline-block;
  position: relative;
  z-index: 0;
}

.coll-section-title__swirl {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: -24px;
  width: 115%;
  min-width: 80px;
  max-width: 240px;
  height: 70px;
  z-index: -1;
  pointer-events: none;
}

/* ── Filter bar ──────────────────────────────────── */
.coll-filterbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  flex-wrap: wrap;
}

.coll-filterbar__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
  flex: 1;
}

.coll-pill {
  display: inline-flex;
  align-items: center;
  padding: 9px 22px;
  border-radius: 24px;
  border: 1.5px solid #ccc;
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 500;
  color: var(--coral-pink, #ff9696);
  text-decoration: none;
  background: #fff;
  border-color: var(--coral-pink, #ff9696);
  transition: background 0.2s, color 0.2s, border-color 0.2s;
  white-space: nowrap;
}

.coll-pill:hover {
  background: var(--coral-pink, #ff9696);
  color: #fff;
}

.coll-pill--active {
  background: var(--coral-pink, #ff9696);
  border-color: var(--coral-pink, #ff9696);
  color: #fff;
}

.coll-pill--active:hover {
  color: #fff;
}

/* ── Price range filter ──────────────────────────── */
.coll-filterbar__price {
  flex-shrink: 0;
  min-width: 200px;
  max-width: 260px;
}

.coll-price-label {
  font-family: var(--font-body);
  font-size: 12px;
  color: #666;
  margin: 0 0 2px;
}

.coll-price-display {
  font-family: var(--font-body);
  font-size: 12px;
  color: #333;
  margin: 0 0 10px;
}

.coll-slider-wrap {
  position: relative;
  height: 20px;
  width: 100%;
}

.coll-slider-track {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 3px;
  background: #e0e0e0;
  border-radius: 2px;
  transform: translateY(-50%);
}

.coll-slider-fill {
  position: absolute;
  top: 50%;
  height: 3px;
  background: var(--coral-pink, #ff9696);
  border-radius: 2px;
  transform: translateY(-50%);
  pointer-events: none;
  z-index: 1;
}

.coll-range {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  -webkit-appearance: none;
  appearance: none;
  background: transparent;
  cursor: pointer;
  pointer-events: none;
  z-index: 2;
}

.coll-range::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: var(--coral-pink, #ff9696);
  border: 2px solid #fff;
  box-shadow: 0 0 0 1.5px var(--coral-pink, #ff9696);
  cursor: pointer;
  pointer-events: all;
}

.coll-range::-moz-range-thumb {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: var(--coral-pink, #ff9696);
  border: 2px solid #fff;
  box-shadow: 0 0 0 1.5px var(--coral-pink, #ff9696);
  cursor: pointer;
  pointer-events: all;
}

/* ── Controls row ────────────────────────────────── */
.coll-controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.coll-controls__count {
  font-family: var(--font-body);
  font-size: 14px;
  color: #666;
}

.coll-sort-drop {
  position: relative;
}

.coll-sort-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 18px;
  background: #fff;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 500;
  color: #333;
  cursor: pointer;
  white-space: nowrap;
  transition: border-color 0.2s, box-shadow 0.2s;
  min-width: 160px;
  justify-content: space-between;
}

.coll-sort-btn:hover,
.coll-sort-drop--open .coll-sort-btn {
  border-color: var(--coral-pink, #ff9696);
  box-shadow: 0 0 0 3px rgba(255,150,150,0.12);
}

.coll-sort-btn__chevron {
  flex-shrink: 0;
  transition: transform 0.2s ease;
  color: #999;
}

.coll-sort-drop--open .coll-sort-btn__chevron {
  transform: rotate(180deg);
}

.coll-sort-list {
  position: absolute;
  top: calc(100% + 6px);
  right: 0;
  min-width: 100%;
  background: #fff;
  border: 1px solid #e8e8e8;
  border-radius: 10px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.10);
  list-style: none;
  margin: 0;
  padding: 6px;
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transform: translateY(-6px);
  transition: opacity 0.18s ease, transform 0.18s ease;
}

.coll-sort-drop--open .coll-sort-list {
  opacity: 1;
  pointer-events: all;
  transform: translateY(0);
}

.coll-sort-option {
  padding: 9px 14px;
  border-radius: 6px;
  font-family: var(--font-body);
  font-size: 14px;
  color: #444;
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
  white-space: nowrap;
}

.coll-sort-option:hover {
  background: #fff5f5;
  color: var(--coral-pink, #ff9696);
}

.coll-sort-option--active {
  color: var(--coral-pink, #ff9696);
  font-weight: 600;
  background: #fff5f5;
}

/* ── Product grid ────────────────────────────────── */
.coll-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px 20px;
  
}

.coll-empty {
  grid-column: 1 / -1;
  text-align: center;
  font-family: var(--font-body);
  font-size: 16px;
  color: #666;
  padding: 40px 0;
}

/* ── Product card ────────────────────────────────── */
.coll-pcard {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.coll-pcard__link {
  display: block;
  text-decoration: none;
  flex-shrink: 0;
}

.coll-pcard__img-wrap {
  display: block;
  width: 100%;
  border-radius: 12px;
  overflow: hidden;
  background: #f5f0ef;
  line-height: 0;
}

.coll-pcard__img-wrap img {
  display: block;
  width: 100%;
  height: 18rem;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.coll-pcard__link:hover .coll-pcard__img-wrap img { transform: scale(1.04); }

.coll-pcard__img--ph {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0e8e8;
}

.coll-pcard__img--ph svg {
  width: 60px;
  height: 60px;
  opacity: 0.25;
}

.coll-pcard__info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.coll-pcard__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.coll-pcard__name {
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 600;
  color: #000;
  text-decoration: none;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}

.coll-pcard__name:hover { color: var(--coral-pink, #ff9696); }

.coll-pcard__acts {
  display: flex;
  gap: 2px;
  flex-shrink: 0;
}

.coll-pcard__act-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s;
}

.coll-pcard__act-btn:hover { opacity: 0.55; }
.coll-pcard__act-btn:disabled { opacity: 0.35; cursor: default; }

.coll-pcard__wish--on path {
  fill: #ff4d4d;
  stroke: #ff4d4d;
}
.coll-pcard__wish--on:hover { opacity: 1; }

.coll-pcard__price {
  font-family: var(--font-body);
  font-size: 15px;
  color: #000;
  margin: 0;
}

/* ── Pagination ──────────────────────────────────── */
.coll-pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding-top: 16px;
}

.coll-page-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border: 1.5px solid var(--coral-pink, #ff9696);
  border-radius: 8px;
  color: var(--coral-pink, #ff9696);
  text-decoration: none;
  background: #fff;
  transition: background 0.2s, color 0.2s;
}

.coll-page-btn:hover {
  background: var(--coral-pink, #ff9696);
  color: #fff;
}

.coll-page-btn--disabled {
  border-color: #e0e0e0;
  color: #ccc;
  pointer-events: none;
}

.coll-page-num {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border: none;
  border-radius: 8px;
  font-family: var(--font-body);
  font-size: 14px;
  color: #666;
  text-decoration: none;
  background: transparent;
  transition: color 0.2s;
}

.coll-page-num:hover { color: var(--coral-pink, #ff9696); }

.coll-page-num--active {
  background: var(--coral-pink, #ff9696);
  color: #fff;
  font-weight: 600;
}

.coll-page-num--active:hover { color: #fff; }

.coll-page-num--gap {
  color: #bbb;
  cursor: default;
}

/* ── Responsive ──────────────────────────────────── */

/* ≤1280px: slightly tighter padding, still 4 columns */
@media (max-width: 1280px) {
  .coll-main__inner { padding: 48px 48px 72px; }
  .coll-banner__title { font-size: 72px; }
}

/* ≤1100px: 3 columns */
@media (max-width: 1100px) {
  .coll-main__inner { padding: 40px 32px 60px; }
  .coll-banner__title { font-size: 60px; }
  .coll-grid { grid-template-columns: repeat(3, 1fr); gap: 20px 16px; }
}

/* ≤900px: 2 columns */
@media (max-width: 900px) {
  .coll-main__inner { padding: 36px 24px 52px; gap: 20px; }
  .coll-banner { height: 60vh; min-height: 320px; }
  .coll-banner__title { font-size: 48px; }
  .coll-banner__text { padding: 0 24px; }
  .coll-section-title { font-size: 30px; }
  .coll-grid { grid-template-columns: repeat(2, 1fr); gap: 16px 12px; }
  .coll-filterbar { flex-direction: column; align-items: flex-start; gap: 12px; }
  .coll-filterbar__tags { gap: 8px; }
  .coll-filterbar__price { max-width: 100%; width: 100%; min-width: unset; }
  .coll-pill { padding: 7px 16px; font-size: 13px; }
  .coll-sort-btn { min-width: unset; padding: 8px 14px; }
}

/* ≤600px: 2 columns mobile */
@media (max-width: 600px) {
  .coll-main__inner { padding: 28px 14px 44px; gap: 14px; }
  .coll-banner { height: 50vh; min-height: 260px; }
  .coll-banner__title { font-size: 32px; }
  .coll-banner__text { padding: 0 16px; }
  .coll-banner__desc { font-size: 14px; }
  .coll-section-title { font-size: 24px; }
  .coll-section-title__swirl {
    bottom: -16px;
    height: 50px;
    min-width: 60px;
    max-width: 180px;
  }
  .coll-grid { grid-template-columns: repeat(2, 1fr); gap: 14px 10px; }
  .coll-pcard__img-wrap img { height: 12rem; }
  .coll-pcard__name { font-size: 13px; white-space: normal; }
  .coll-pcard__price { font-size: 13px; }
  .coll-pcard__act-btn { width: 22px; height: 22px; }
  .coll-pcard__act-btn svg { width: 18px; height: 18px; }
  .coll-controls { gap: 8px; }
  .coll-controls__count { font-size: 13px; }
  .coll-sort-btn { font-size: 12px; padding: 7px 12px; }
  .coll-pill { padding: 6px 12px; font-size: 12px; }
  .coll-filterbar__tags { gap: 6px; }
}

/* ≤400px: extra small phones */
@media (max-width: 400px) {
  .coll-main__inner { padding: 20px 10px 36px; }
  .coll-banner__title { font-size: 26px; }
  .coll-section-title { font-size: 20px; }
  .coll-pcard__img-wrap img { height: 10rem; }
  .coll-pill { padding: 5px 10px; font-size: 11px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "header",
      "content": "Banner"
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Fallback banner image",
      "info": "Shown when a collection has no image (e.g. All Products)"
    },
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "heading_prefix",
      "label": "Heading prefix",
      "default": "Our"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12
    },
    {
      "type": "header",
      "content": "Price filter"
    },
    {
      "type": "checkbox",
      "id": "show_price_filter",
      "label": "Show price range filter",
      "default": true
    },
    {
      "type": "number",
      "id": "price_max",
      "label": "Maximum price (in your store currency, e.g. 150000 for LKR 150,000)",
      "default": 150000
    }
  ],
  "presets": [
    {
      "name": "Collection"
    }
  ]
}
{% endschema %}
