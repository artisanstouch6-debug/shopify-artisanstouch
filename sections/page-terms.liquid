<div class="policy-page full-width">

  <div class="policy-page__hero">
    <div class="policy-page__hero-inner">
      {% if section.settings.eyebrow != blank %}
        <p class="policy-page__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h1 class="policy-page__title">{{ section.settings.title | default: page.title }}</h1>
      <div class="policy-page__rule">
        <span class="policy-page__rule-line"></span>
        <span class="policy-page__rule-diamond"></span>
        <span class="policy-page__rule-line"></span>
      </div>
    </div>
  </div>

  <div class="policy-page__body">
    <div class="policy-page__content">

      {% if section.settings.intro != blank %}
        <div class="policy-intro">{{ section.settings.intro }}</div>
      {% endif %}

      {% for block in section.blocks %}
        {% if block.type == 'policy_section' %}
          <div class="policy-section{% if block.settings.highlight %} policy-section--contact{% endif %}" {{ block.shopify_attributes }}>
            {% if block.settings.heading != blank %}
              <h2>{{ block.settings.heading }}</h2>
            {% endif %}
            <div class="policy-section__body">{{ block.settings.content }}</div>
          </div>
        {% endif %}
      {% endfor %}

    </div>
  </div>

</div>

{% stylesheet %}
  .policy-page { grid-column: 1 / -1; width: 100%; }

  .policy-page__hero {
    background: linear-gradient(135deg, #1a0f06 0%, #2d1a08 50%, #1a0f06 100%);
    padding: 80px 24px 72px; text-align: center;
  }
  .policy-page__hero-inner { max-width: 640px; margin: 0 auto; }
  .policy-page__eyebrow {
    font-family: var(--font-body); font-size: 12px; font-weight: 500;
    letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--brand-gold, #c9a96e); margin: 0 0 16px;
  }
  .policy-page__title {
    font-family: var(--font-heading); font-size: 52px; font-weight: 400;
    color: #fff; margin: 0 0 24px; line-height: 1.1;
  }
  .policy-page__rule {
    display: flex; align-items: center; justify-content: center; gap: 16px;
  }
  .policy-page__rule-line {
    width: 80px; height: 1px;
    background: linear-gradient(to right, transparent, var(--brand-gold, #c9a96e));
  }
  .policy-page__rule-line:last-child {
    background: linear-gradient(to left, transparent, var(--brand-gold, #c9a96e));
  }
  .policy-page__rule-diamond {
    width: 8px; height: 8px; background: var(--brand-gold, #c9a96e);
    transform: rotate(45deg); flex-shrink: 0;
  }

  .policy-page__body { background: #fff8f8; padding: 72px 24px 96px; }
  .policy-page__content { max-width: 780px; margin: 0 auto; }

  .policy-intro {
    font-family: var(--font-body); font-size: 17px; color: #555;
    line-height: 1.8; margin: 0 0 48px;
    padding-bottom: 32px; border-bottom: 1px solid #e8d8cc;
  }
  .policy-intro p { margin: 0; }

  .policy-section { margin-bottom: 40px; }
  .policy-section h2 {
    font-family: var(--font-heading); font-size: 22px; font-weight: 600;
    color: #1a1a1a; margin: 0 0 12px;
    padding-bottom: 8px; border-bottom: 2px solid var(--brand-gold, #c9a96e);
    display: inline-block;
  }
  .policy-section__body p {
    font-family: var(--font-body); font-size: 15px; color: #555;
    line-height: 1.85; margin: 12px 0 0;
  }
  .policy-section__body a {
    color: var(--coral-pink, #ff9696); text-decoration: underline;
    text-underline-offset: 2px;
  }
  .policy-section__body ul, .policy-section__body ol {
    font-family: var(--font-body); font-size: 15px; color: #555;
    line-height: 1.85; margin: 12px 0 0; padding-left: 20px;
  }
  .policy-section__body li { margin-bottom: 6px; }
  .policy-section__body strong { color: #333; }

  .policy-section--contact {
    background: #f5e6da; border-radius: 16px; padding: 32px 36px; margin-top: 56px;
  }
  .policy-section--contact h2 { border-color: var(--coral-pink, #ff9696); }

  @media (max-width: 768px) {
    .policy-page__title { font-size: 36px; }
    .policy-page__hero { padding: 56px 20px 52px; }
    .policy-page__body { padding: 48px 20px 72px; }
    .policy-section--contact { padding: 24px 20px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Terms & Conditions",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Artisans Touch"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Page title",
      "default": "Terms & Conditions"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Introduction paragraph"
    }
  ],
  "blocks": [
    {
      "type": "policy_section",
      "name": "Policy Section",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Section heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Section content"
        },
        {
          "type": "checkbox",
          "id": "highlight",
          "label": "Highlight background (for contact section)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    { "name": "Terms & Conditions" }
  ]
}
{% endschema %}
